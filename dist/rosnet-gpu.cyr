# ===========================================================================
# 1.8.1 — layernorm forward (bit-exact). ln_fwd uses SEQUENTIAL reductions, so a
# tiled sequential-sum GPU kernel matches it bit-for-bit. Three passes (the 256-id
# cap forbids a full per-row unroll): pass1 tiled Σx → S[m]; host mean = S/C; pass2
# tiled Σ(x-mu)² → V[m]; host rstd = 1/sqrt(V/C+eps); pass3 elementwise normalize.
# ===========================================================================

# Shared preamble for an nbind-buffer f64 compute kernel (LocalSize 1, gid builtin).
# Fixed ids %1..%10 (types/ptrs) + %11 gid; buffers %12..%(11+nbind). fnid passed in.
# id-bound left 0 at byte 12 (the kernel patches it). Returns the byte offset.
fn _gpu_pre(buf, nbind, fnid): i64 {
    var o = _gpu_op3(buf, 0, 0x07230203, 0x00010300, 0x00000000);
    o = _gpu_op2(buf, o, 0x00000000, 0x00000000);                       # id-bound(patch) + schema
    o = _gpu_op2(buf, o, 0x00020011, 1);                                # Capability Shader
    o = _gpu_op2(buf, o, 0x00020011, 10);                               # Capability Float64
    o = _gpu_op3(buf, o, 0x0003000E, 0, 1);                             # MemoryModel
    o = _gpu_op6(buf, o, 0x0006000F, 5, fnid, 0x6E69616D, 0x00000000, 11);  # EntryPoint "main" gid
    o = _gpu_op6(buf, o, 0x00060010, fnid, 17, 1, 1, 1);               # ExecutionMode LocalSize 1
    o = _gpu_op4(buf, o, 0x00040047, 11, 11, 28);                      # gid BuiltIn GlobalInvocationId
    var i = 0;
    while (i < nbind) {
        o = _gpu_op4(buf, o, 0x00040047, 12 + i, 33, i);              # Binding i
        o = _gpu_op4(buf, o, 0x00040047, 12 + i, 34, 0);              # DescriptorSet 0
        i = i + 1;
    }
    o = _gpu_op2(buf, o, 0x00020013, 1);                              # %1 void
    o = _gpu_op3(buf, o, 0x00030021, 2, 1);                           # %2 fn void()
    o = _gpu_op4(buf, o, 0x00040015, 3, 32, 0);                       # %3 uint
    o = _gpu_op4(buf, o, 0x00040017, 4, 3, 3);                        # %4 uvec3
    o = _gpu_op4(buf, o, 0x00040020, 5, 1, 4);                        # %5 ptr Input uvec3
    o = _gpu_op3(buf, o, 0x00030016, 6, 64);                          # %6 double
    o = _gpu_op3(buf, o, 0x0003001D, 7, 6);                           # %7 runtimearray double
    o = _gpu_op3(buf, o, 0x0003001E, 8, 7);                           # %8 struct
    o = _gpu_op4(buf, o, 0x00040020, 9, 12, 8);                       # %9 ptr StorageBuffer struct
    o = _gpu_op4(buf, o, 0x00040020, 10, 12, 6);                      # %10 ptr StorageBuffer double
    o = _gpu_op4(buf, o, 0x0004003B, 5, 11, 1);                       # %11 gid var Input
    i = 0;
    while (i < nbind) { o = _gpu_op4(buf, o, 0x0004003B, 9, 12 + i, 12); i = i + 1; }  # buffer vars
    return o;
}

# pass1 mean tile: bindings x=0(%12), S=1(%13). S[m] += Σ_{j<TK} x[m*C + c0 + j].
# consts %14=0 %15=C %16=c0 %17=1. fn %18. One thread per row m (grid M).
fn _gpu_build_mean(buf, C, c0, TK): i64 {
    var o = _gpu_pre(buf, 2, 18);
    o = _gpu_op4(buf, o, 0x0004002B, 3, 14, 0);
    o = _gpu_op4(buf, o, 0x0004002B, 3, 15, C);
    o = _gpu_op4(buf, o, 0x0004002B, 3, 16, c0);
    o = _gpu_op4(buf, o, 0x0004002B, 3, 17, 1);
    o = _gpu_op5(buf, o, 0x00050036, 1, 18, 0, 2);
    o = _gpu_op2(buf, o, 0x000200F8, 19);
    o = _gpu_op4(buf, o, 0x0004003D, 4, 20, 11);                      # gid
    o = _gpu_op5(buf, o, 0x00050051, 3, 21, 20, 0);                  # m = gid.x
    o = _gpu_op5(buf, o, 0x00050084, 3, 22, 21, 15);                # mC = m*C
    o = _gpu_op6(buf, o, 0x00060041, 10, 23, 13, 14, 21);          # &S[m]
    o = _gpu_op4(buf, o, 0x0004003D, 6, 24, 23);                    # acc = S[m]
    o = _gpu_op5(buf, o, 0x00050080, 3, 25, 22, 16);               # xi = mC + c0
    var xi = 25; var acc = 24; var nid = 26;
    var j = 0;
    while (j < TK) {
        var xp = nid; nid = nid + 1;
        o = _gpu_op6(buf, o, 0x00060041, 10, xp, 12, 14, xi);       # &x[xi]
        var xv = nid; nid = nid + 1;
        o = _gpu_op4(buf, o, 0x0004003D, 6, xv, xp);               # x[xi]
        var an = nid; nid = nid + 1;
        o = _gpu_op5(buf, o, 0x00050081, 6, an, acc, xv);          # acc += x
        acc = an;
        if (j < TK - 1) { var xn = nid; nid = nid + 1; o = _gpu_op5(buf, o, 0x00050080, 3, xn, xi, 17); xi = xn; }
        j = j + 1;
    }
    o = _gpu_op3(buf, o, 0x0003003E, 23, acc);                      # S[m] = acc
    o = _gpu_op2(buf, o, 0x000100FD, 0x00010038);
    store32(buf + 12, nid);
    return o;
}

# pass2 var tile: bindings x=0(%12), MU=1(%13), V=2(%14). V[m] += Σ (x-mu)².
# consts %15=0 %16=C %17=c0 %18=1. fn %19.
fn _gpu_build_var(buf, C, c0, TK): i64 {
    var o = _gpu_pre(buf, 3, 19);
    o = _gpu_op4(buf, o, 0x0004002B, 3, 15, 0);
    o = _gpu_op4(buf, o, 0x0004002B, 3, 16, C);
    o = _gpu_op4(buf, o, 0x0004002B, 3, 17, c0);
    o = _gpu_op4(buf, o, 0x0004002B, 3, 18, 1);
    o = _gpu_op5(buf, o, 0x00050036, 1, 19, 0, 2);
    o = _gpu_op2(buf, o, 0x000200F8, 20);
    o = _gpu_op4(buf, o, 0x0004003D, 4, 21, 11);                      # gid
    o = _gpu_op5(buf, o, 0x00050051, 3, 22, 21, 0);                  # m
    o = _gpu_op5(buf, o, 0x00050084, 3, 23, 22, 16);               # mC
    o = _gpu_op6(buf, o, 0x00060041, 10, 24, 13, 15, 22);         # &MU[m]
    o = _gpu_op4(buf, o, 0x0004003D, 6, 25, 24);                   # mu
    o = _gpu_op6(buf, o, 0x00060041, 10, 26, 14, 15, 22);         # &V[m]
    o = _gpu_op4(buf, o, 0x0004003D, 6, 27, 26);                   # acc = V[m]
    o = _gpu_op5(buf, o, 0x00050080, 3, 28, 23, 17);              # xi = mC + c0
    var xi = 28; var acc = 27; var nid = 29;
    var j = 0;
    while (j < TK) {
        var xp = nid; nid = nid + 1;
        o = _gpu_op6(buf, o, 0x00060041, 10, xp, 12, 15, xi);       # &x[xi]
        var xv = nid; nid = nid + 1;
        o = _gpu_op4(buf, o, 0x0004003D, 6, xv, xp);
        var d = nid; nid = nid + 1;
        o = _gpu_op5(buf, o, 0x00050083, 6, d, xv, 25);            # d = x - mu (FSub)
        var sq = nid; nid = nid + 1;
        o = _gpu_op5(buf, o, 0x00050085, 6, sq, d, d);             # d*d (FMul)
        var an = nid; nid = nid + 1;
        o = _gpu_op5(buf, o, 0x00050081, 6, an, acc, sq);          # acc += d*d
        acc = an;
        if (j < TK - 1) { var xn = nid; nid = nid + 1; o = _gpu_op5(buf, o, 0x00050080, 3, xn, xi, 18); xi = xn; }
        j = j + 1;
    }
    o = _gpu_op3(buf, o, 0x0003003E, 26, acc);                     # V[m] = acc
    o = _gpu_op2(buf, o, 0x000100FD, 0x00010038);
    store32(buf + 12, nid);
    return o;
}

# pass3 normalize (elementwise, 1 thread per (m,c) = grid M*C). bindings
# x=0(%12) MU=1(%13) RS=2(%14) gamma=3(%15) beta=4(%16) y=5(%17).
# y[idx] = (x[idx]-MU[m])*RS[m]*gamma[c]+beta[c], m=idx/C, c=idx%C. consts %18=0 %19=C. fn %20.
fn _gpu_build_norm(buf, C): i64 {
    var o = _gpu_pre(buf, 6, 20);
    o = _gpu_op4(buf, o, 0x0004002B, 3, 18, 0);
    o = _gpu_op4(buf, o, 0x0004002B, 3, 19, C);
    o = _gpu_op5(buf, o, 0x00050036, 1, 20, 0, 2);
    o = _gpu_op2(buf, o, 0x000200F8, 21);
    o = _gpu_op4(buf, o, 0x0004003D, 4, 22, 11);                      # gid
    o = _gpu_op5(buf, o, 0x00050051, 3, 23, 22, 0);                  # idx
    o = _gpu_op5(buf, o, 0x00050086, 3, 24, 23, 19);               # m = idx/C (UDiv)
    o = _gpu_op5(buf, o, 0x00050089, 3, 25, 23, 19);               # c = idx%C (UMod)
    o = _gpu_op6(buf, o, 0x00060041, 10, 26, 12, 18, 23);         # &x[idx]
    o = _gpu_op4(buf, o, 0x0004003D, 6, 27, 26);                   # xv
    o = _gpu_op6(buf, o, 0x00060041, 10, 28, 13, 18, 24);         # &MU[m]
    o = _gpu_op4(buf, o, 0x0004003D, 6, 29, 28);                   # mu
    o = _gpu_op6(buf, o, 0x00060041, 10, 30, 14, 18, 24);         # &RS[m]
    o = _gpu_op4(buf, o, 0x0004003D, 6, 31, 30);                   # rs
    o = _gpu_op5(buf, o, 0x00050083, 6, 32, 27, 29);              # d = x - mu
    o = _gpu_op5(buf, o, 0x00050085, 6, 33, 32, 31);             # xh = d*rs
    o = _gpu_op6(buf, o, 0x00060041, 10, 34, 15, 18, 25);        # &gamma[c]
    o = _gpu_op4(buf, o, 0x0004003D, 6, 35, 34);                  # g
    o = _gpu_op5(buf, o, 0x00050085, 6, 36, 33, 35);            # xh*g
    o = _gpu_op6(buf, o, 0x00060041, 10, 37, 16, 18, 25);       # &beta[c]
    o = _gpu_op4(buf, o, 0x0004003D, 6, 38, 37);                 # b
    o = _gpu_op5(buf, o, 0x00050081, 6, 39, 36, 38);           # o = xh*g + b
    o = _gpu_op6(buf, o, 0x00060041, 10, 40, 17, 18, 23);      # &y[idx]
    o = _gpu_op3(buf, o, 0x0003003E, 40, 39);                  # y[idx] = o
    o = _gpu_op2(buf, o, 0x000100FD, 0x00010038);
    store32(buf + 12, 41);
    return o;
}

# Pack (K, N, k0) into a cache key (each field < 2^20 for any attn11 shape).
fn _gpu_pack(K, N, k0): i64 { return (K << 40) | (N << 20) | k0; }

fn _gpu_cache_get(key): i64 {
    var i = 0;
    while (i < _gpu_cn) {
        if (load64(&_gpu_ck + i * 8) == key) { return load64(&_gpu_cv + i * 8); }
        i = i + 1;
    }
    return 0;
}

fn _gpu_cache_put(key, val): i64 {
    if (_gpu_cn >= 128) { return 0; }   # cache full: skip (caller still uses the handle)
    store64(&_gpu_ck + _gpu_cn * 8, key);
    store64(&_gpu_cv + _gpu_cn * 8, val);
    _gpu_cn = _gpu_cn + 1;
    return 0;
}

# Get (compile+cache) the tile shader for (K, N, k0). 0 = unavailable (CPU fallback).
fn _gpu_get_tile(K, N, k0): i64 {
    var key = _gpu_pack(K, N, k0);
    var c = _gpu_cache_get(key);
    if (c == (0 - 1)) { return 0; }     # known compile-fail
    if (c != 0) { return c; }
    var spv[8192];
    var nbytes = _gpu_build_tile(&spv, K, N, k0, GPU_TK());
    var shmod = gpu_shader_module_create_spirv(_gpu_ctx, &spv, nbytes);
    if (shmod == 0) { _gpu_cache_put(key, 0 - 1); return 0; }
    _gpu_cache_put(key, shmod);
    return shmod;
}

# 1.9.0: forward tile with an explicit unroll length `tk` (≤ GPU_TK) so a contraction dim that
# isn't a multiple of GPU_TK finishes with a short final tile — lets the LM-head backward's D_f
# (contracts the vocab V) run on-device for ANY vocab. Kind-tagged key (kind 21, incl. k0,tk) so it
# never collides with the full-tile / matmul cache. 0 = unavailable (CPU fallback).
fn _gpu_get_tile_n(K, N, k0, tk): i64 {
    var key = (21 << 56) | (K << 34) | (N << 19) | (k0 << 5) | tk;
    var c = _gpu_cache_get(key);
    if (c == (0 - 1)) { return 0; }
    if (c != 0) { return c; }
    var spv[8192];
    var nbytes = _gpu_build_tile(&spv, K, N, k0, tk);
    var shmod = gpu_shader_module_create_spirv(_gpu_ctx, &spv, nbytes);
    if (shmod == 0) { _gpu_cache_put(key, 0 - 1); return 0; }
    _gpu_cache_put(key, shmod);
    return shmod;
}

# Allocate one GTT buffer + map it at `va`; write {handle, host_map} into out[16].
# 0 = ok; -1 = fail (the BO is released on a map failure). GTT is CPU-visible.
fn _gpu_alloc1(fd, va, sz, out): i64 {
    if (native_bo_create_gtt(fd, sz, out) != 0) { return 0 - 1; }
    var h = load64(out + 0); var m = load64(out + 8);
    if (native_gem_va_map(fd, h, va, sz, _NATIVE_PERM_DATA) != 0) {
        native_bo_release_gtt(fd, h, m, sz);
        return 0 - 1;
    }
    return 0;
}

# Unmap + release one buffer (if its handle is set). The teardown's per-buffer step.
fn _gpu_rel1(fd, h, m, va, sz): i64 {
    if (h == 0) { return 0; }
    native_gem_va_unmap(fd, h, va, sz);
    native_bo_release_gtt(fd, h, m, sz);
    return 0;
}

# Release every allocated GPU buffer + the ctx, mark unavailable. Guards 0 handles, so
# it is the single error-unwind for a partially-initialized _gpu_init.
fn _gpu_teardown(): i64 {
    var fd = native_ctx_fd(_gpu_ctx);
    var sz = GPU_BO_MAX();
    _gpu_rel1(fd, _gpu_xh, _gpu_xm, _GPU_XVA(), sz);    _gpu_xh = 0;
    _gpu_rel1(fd, _gpu_wh, _gpu_wm, _GPU_WVA(), sz);    _gpu_wh = 0;
    _gpu_rel1(fd, _gpu_yh, _gpu_ym, _GPU_YVA(), sz);    _gpu_yh = 0;
    _gpu_rel1(fd, _gpu_gh, _gpu_gm, _GPU_GVA(), sz);    _gpu_gh = 0;
    _gpu_rel1(fd, _gpu_bbh, _gpu_bbm, _GPU_BVA(), sz);  _gpu_bbh = 0;
    _gpu_rel1(fd, _gpu_sh, _gpu_sm, _GPU_SVA(), sz);    _gpu_sh = 0;
    _gpu_rel1(fd, _gpu_vh, _gpu_vm, _GPU_VVA(), sz);    _gpu_vh = 0;
    gpu_context_release(_gpu_ctx);
    _gpu_state = 2;
    return 0;
}

# Lazy device bring-up: open the native ctx + allocate/map the 7 persistent data
# buffers once (x/W/y for matmul; gamma/beta/S/V add layernorm). 1 = ready, 0 =
# unavailable (clean CPU fallback, never fatal).
fn _gpu_init(): i64 {
    if (_gpu_state == 1) { return 1; }
    if (_gpu_state == 2) { return 0; }
    var res = gpu_context_new_native();
    if (is_err_result(res) == 1) { _gpu_state = 2; return 0; }
    _gpu_ctx = payload(res);
    var fd = native_ctx_fd(_gpu_ctx);
    var sz = GPU_BO_MAX();
    var bo[16];
    if (_gpu_alloc1(fd, _GPU_XVA(), sz, &bo) != 0) { _gpu_teardown(); return 0; }
    _gpu_xh = load64(&bo + 0); _gpu_xm = load64(&bo + 8);
    if (_gpu_alloc1(fd, _GPU_WVA(), sz, &bo) != 0) { _gpu_teardown(); return 0; }
    _gpu_wh = load64(&bo + 0); _gpu_wm = load64(&bo + 8);
    if (_gpu_alloc1(fd, _GPU_YVA(), sz, &bo) != 0) { _gpu_teardown(); return 0; }
    _gpu_yh = load64(&bo + 0); _gpu_ym = load64(&bo + 8);
    if (_gpu_alloc1(fd, _GPU_GVA(), sz, &bo) != 0) { _gpu_teardown(); return 0; }
    _gpu_gh = load64(&bo + 0); _gpu_gm = load64(&bo + 8);
    if (_gpu_alloc1(fd, _GPU_BVA(), sz, &bo) != 0) { _gpu_teardown(); return 0; }
    _gpu_bbh = load64(&bo + 0); _gpu_bbm = load64(&bo + 8);
    if (_gpu_alloc1(fd, _GPU_SVA(), sz, &bo) != 0) { _gpu_teardown(); return 0; }
    _gpu_sh = load64(&bo + 0); _gpu_sm = load64(&bo + 8);
    if (_gpu_alloc1(fd, _GPU_VVA(), sz, &bo) != 0) { _gpu_teardown(); return 0; }
    _gpu_vh = load64(&bo + 0); _gpu_vm = load64(&bo + 8);
    _gpu_state = 1;
    return 1;
}

# GPU forward matmul: y(M,N) = b(N) + x(M,K)·W(K,N), all row-major f64. Returns 0 on
# success (y written), -1 = "cannot GPU this — use CPU". Bit-exact vs linear_fwd.
fn gpu_matmul_fwd(x, W, b, y, M, K, N): i64 {
    if (_gpu_init() == 0) { return 0 - 1; }
    var TK = GPU_TK();
    if (K <= 0) { return 0 - 1; }
    if ((K % TK) != 0) { return 0 - 1; }                 # 1.8.0: K must tile by GPU_TK
    if ((M * N) <= 0) { return 0 - 1; }
    if ((M * N) > MABDA_MAX_DISPATCH_DIM) { return 0 - 1; }
    if ((M * K * 8) > GPU_BO_MAX()) { return 0 - 1; }
    if ((K * N * 8) > GPU_BO_MAX()) { return 0 - 1; }
    if ((M * N * 8) > GPU_BO_MAX()) { return 0 - 1; }
    # upload x, W to the host-visible GTT maps
    var i = 0; var nx = M * K;
    while (i < nx) { store64(_gpu_xm + i * 8, load64(x + i * 8)); i = i + 1; }
    i = 0; var nw = K * N;
    while (i < nw) { store64(_gpu_wm + i * 8, load64(W + i * 8)); i = i + 1; }
    # pre-fill y with the bias (or 0) — every tile then accumulates onto it
    var m = 0;
    while (m < M) {
        var nn = 0;
        while (nn < N) {
            var v = f64_from(0);
            if (b != 0) { v = load64(b + nn * 8); }
            store64(_gpu_ym + (m * N + nn) * 8, v);
            nn = nn + 1;
        }
        m = m + 1;
    }
    # tiled dispatch (serialized — native_compute_dispatch waits, so no race on y)
    var MN = M * N;
    var k0 = 0;
    while (k0 < K) {
        var sh = _gpu_get_tile(K, N, k0);
        if (sh == 0) { return 0 - 1; }   # compile cap hit → CPU (caller's y untouched)
        var bp[56];
        store64(&bp + 0, 3);
        store64(&bp + 8, _gpu_xh);  store64(&bp + 16, _GPU_XVA());
        store64(&bp + 24, _gpu_wh); store64(&bp + 32, _GPU_WVA());
        store64(&bp + 40, _gpu_yh); store64(&bp + 48, _GPU_YVA());
        if (gpu_compute_dispatch(_gpu_ctx, sh, MN, 1, 1, &bp) != 0) { return 0 - 1; }
        k0 = k0 + TK;
    }
    # read y back from the GTT map
    i = 0;
    while (i < MN) { store64(y + i * 8, load64(_gpu_ym + i * 8)); i = i + 1; }
    _gpu_mm_count = _gpu_mm_count + 1;
    return 0;
}

# Get (compile+cache) an ln kernel. kind 1=mean, 2=var, 3=norm. Keys are tagged with
# kind<<56 so they never collide with matmul tile keys. 0 = unavailable (CPU fallback).
fn _gpu_get_ln(kind, C, c0): i64 {
    var key = (kind << 56) | (C << 20) | c0;
    var c = _gpu_cache_get(key);
    if (c == (0 - 1)) { return 0; }
    if (c != 0) { return c; }
    var spv[8192];
    var nbytes = 0;
    if (kind == 1) { nbytes = _gpu_build_mean(&spv, C, c0, GPU_TK()); }
    elif (kind == 2) { nbytes = _gpu_build_var(&spv, C, c0, GPU_TK()); }
    else { nbytes = _gpu_build_norm(&spv, C); }
    var shmod = gpu_shader_module_create_spirv(_gpu_ctx, &spv, nbytes);
    if (shmod == 0) { _gpu_cache_put(key, 0 - 1); return 0; }
    _gpu_cache_put(key, shmod);
    return shmod;
}

# GPU forward layernorm: y(M,C) = ((x-mean)/sqrt(var+eps))*gamma + beta per row, with
# mean[M]/rstd[M] written for the (CPU) backward. Returns 0 on success, -1 = use CPU.
# BIT-EXACT vs ln_fwd: the sequential tiled Σ matches its sequential CPU reduction, and
# the per-row scalars (mean=S*invC, rstd=1/sqrt(V*invC+eps)) are computed identically.
fn gpu_ln_fwd(x, gamma, beta, y, mean, rstd, M, C): i64 {
    if (_gpu_init() == 0) { return 0 - 1; }
    var TK = GPU_TK();
    if (C <= 0) { return 0 - 1; }
    if ((C % TK) != 0) { return 0 - 1; }                 # 1.8.1: C must tile by GPU_TK
    if (M <= 0) { return 0 - 1; }
    if ((M * C) > MABDA_MAX_DISPATCH_DIM) { return 0 - 1; }   # pass-3 grid
    if ((M * C * 8) > GPU_BO_MAX()) { return 0 - 1; }
    if ((C * 8) > GPU_BO_MAX()) { return 0 - 1; }
    var invC = f64_div(f64_from(1), f64_from(C));
    var eps = f64_div(f64_from(1), f64_from(100000));    # == _eps_ln() (1e-5), inlined
    # upload x, gamma, beta; zero the Σ accumulator S
    var i = 0; var nx = M * C;
    while (i < nx) { store64(_gpu_xm + i * 8, load64(x + i * 8)); i = i + 1; }
    i = 0;
    while (i < C) {
        store64(_gpu_gm + i * 8, load64(gamma + i * 8));
        store64(_gpu_bbm + i * 8, load64(beta + i * 8));
        i = i + 1;
    }
    i = 0;
    while (i < M) { store64(_gpu_sm + i * 8, f64_from(0)); i = i + 1; }
    # pass 1: tiled Σx → S[m]
    var c0 = 0;
    while (c0 < C) {
        var sh = _gpu_get_ln(1, C, c0);
        if (sh == 0) { return 0 - 1; }
        var bp[40];
        store64(&bp + 0, 2);
        store64(&bp + 8, _gpu_xh); store64(&bp + 16, _GPU_XVA());
        store64(&bp + 24, _gpu_sh); store64(&bp + 32, _GPU_SVA());
        if (gpu_compute_dispatch(_gpu_ctx, sh, M, 1, 1, &bp) != 0) { return 0 - 1; }
        c0 = c0 + TK;
    }
    # host: mean = S * invC (in place in S buffer); record mean[]
    i = 0;
    while (i < M) {
        var mu = f64_mul(load64(_gpu_sm + i * 8), invC);
        store64(_gpu_sm + i * 8, mu); store64(mean + i * 8, mu);
        i = i + 1;
    }
    i = 0;
    while (i < M) { store64(_gpu_vm + i * 8, f64_from(0)); i = i + 1; }   # zero V
    # pass 2: tiled Σ(x-mu)² → V[m] (reads mean from S buffer)
    c0 = 0;
    while (c0 < C) {
        var sh2 = _gpu_get_ln(2, C, c0);
        if (sh2 == 0) { return 0 - 1; }
        var bp2[56];
        store64(&bp2 + 0, 3);
        store64(&bp2 + 8, _gpu_xh);  store64(&bp2 + 16, _GPU_XVA());
        store64(&bp2 + 24, _gpu_sh); store64(&bp2 + 32, _GPU_SVA());   # mean
        store64(&bp2 + 40, _gpu_vh); store64(&bp2 + 48, _GPU_VVA());   # V
        if (gpu_compute_dispatch(_gpu_ctx, sh2, M, 1, 1, &bp2) != 0) { return 0 - 1; }
        c0 = c0 + TK;
    }
    # host: rstd = 1/sqrt(V*invC + eps) (in place in V buffer); record rstd[]
    i = 0;
    while (i < M) {
        var vv = f64_mul(load64(_gpu_vm + i * 8), invC);
        var rs = f64_div(f64_from(1), f64_sqrt(f64_add(vv, eps)));
        store64(_gpu_vm + i * 8, rs); store64(rstd + i * 8, rs);
        i = i + 1;
    }
    # pass 3: elementwise normalize → y. bindings x, mean(S), rstd(V), gamma, beta, y
    var sh3 = _gpu_get_ln(3, C, 0);
    if (sh3 == 0) { return 0 - 1; }
    var bp3[112];
    store64(&bp3 + 0, 6);
    store64(&bp3 + 8,  _gpu_xh);  store64(&bp3 + 16, _GPU_XVA());
    store64(&bp3 + 24, _gpu_sh);  store64(&bp3 + 32, _GPU_SVA());   # mean
    store64(&bp3 + 40, _gpu_vh);  store64(&bp3 + 48, _GPU_VVA());   # rstd
    store64(&bp3 + 56, _gpu_gh);  store64(&bp3 + 64, _GPU_GVA());   # gamma
    store64(&bp3 + 72, _gpu_bbh); store64(&bp3 + 80, _GPU_BVA());   # beta
    store64(&bp3 + 88, _gpu_yh);  store64(&bp3 + 96, _GPU_YVA());   # y
    if (gpu_compute_dispatch(_gpu_ctx, sh3, M * C, 1, 1, &bp3) != 0) { return 0 - 1; }
    # read y back
    i = 0;
    while (i < nx) { store64(y + i * 8, load64(_gpu_ym + i * 8)); i = i + 1; }
    _gpu_ln_count = _gpu_ln_count + 1;
    return 0;
}

# ===========================================================================
# 1.8.2 — transcendental ops (GELU), TOLERANCE-validated (not bit-exact). f64 exp is an
# x86 hardware builtin with no SPIR-V bit-exact equivalent, so the in-shader exp (Cody-Waite
# range reduction + 11-term Taylor Horner + ldexp, transliterated from math.cyr's aarch64
# polyfill) matches the CPU only to ~1e-13. These break the byte-identical --gpu invariant,
# so they ride a SEPARATE gate (g_gpu_tc / --gpu-tc); plain --gpu stays bit-exact.
# See docs/architecture/010-gpu-transcendentals.md.
# ===========================================================================

# Emit exp(%xid) inline. Uses fixed const ids LOG2E=%17 LN2=%18 MAGIC=%19, c10..c0=%20..%30;
# signed int %12, double %7, GLSL.std.450 import %1. st[0]=nid (in/out); result id → st[1].
fn _gpu_emit_exp(buf, o, xid, st): i64 {
    var nid = load64(st);
    var y = nid; nid = nid + 1;  o = _gpu_op5(buf, o, 0x00050085, 7, y, xid, 17);   # y = x*LOG2E
    var t1 = nid; nid = nid + 1; o = _gpu_op5(buf, o, 0x00050081, 7, t1, y, 19);    # y+MAGIC
    var nf = nid; nid = nid + 1; o = _gpu_op5(buf, o, 0x00050083, 7, nf, t1, 19);   # round: (y+M)-M
    var m1 = nid; nid = nid + 1; o = _gpu_op5(buf, o, 0x00050085, 7, m1, nf, 18);   # nf*LN2
    var r = nid; nid = nid + 1;  o = _gpu_op5(buf, o, 0x00050083, 7, r, xid, m1);   # r = x - nf*LN2
    var p = 20; var ci = 21;
    while (ci <= 30) {                                          # Horner: p = c + r*p, c9..c0
        var mul = nid; nid = nid + 1; o = _gpu_op5(buf, o, 0x00050085, 7, mul, r, p);
        var add = nid; nid = nid + 1; o = _gpu_op5(buf, o, 0x00050081, 7, add, ci, mul);
        p = add; ci = ci + 1;
    }
    var ni = nid; nid = nid + 1;  o = _gpu_op4(buf, o, 0x0004006E, 12, ni, nf);          # i32(nf)
    var res = nid; nid = nid + 1; o = _gpu_op7(buf, o, 0x0007000C, 7, res, 1, 53, p, ni); # ldexp(p,ni)
    store64(st, nid); store64(st + 8, res);
    return o;
}

# GELU kernel: bindings x=0(%14), y=1(%15), one thread per element (grid n).
# y = 0.5·x·(1+tanh(inner)), inner = c·(x+a·x³), tanh(z) = (eᶻ−e⁻ᶻ)/(eᶻ+e⁻ᶻ) — exp inlined ×2.
# Preamble carries the GLSL import (%1) + signed-int type (%12). Consts %16..%35. Fn %36.
fn _gpu_build_gelu(buf): i64 {
    var cbits = f64_sqrt(f64_div(f64_from(2), F64_PI));            # == _gelu_c() sqrt(2/pi)
    var abits = f64_div(f64_from(44715), f64_from(1000000));       # == _gelu_a() 0.044715
    var o = _gpu_op3(buf, 0, 0x07230203, 0x00010300, 0x00000000);
    var bound_off = o; o = _gpu_op2(buf, o, 0x00000000, 0x00000000);
    o = _gpu_op2(buf, o, 0x00020011, 1); o = _gpu_op2(buf, o, 0x00020011, 10);
    o = _gpu_op3(buf, o, 0x0006000B, 1, 0x4C534C47);              # OpExtInstImport %1 "GLSL.std.450"
    store32(buf + o, 0x6474732E); store32(buf + o + 4, 0x3035342E); store32(buf + o + 8, 0x00000000); o = o + 12;
    o = _gpu_op3(buf, o, 0x0003000E, 0, 1);
    o = _gpu_op6(buf, o, 0x0006000F, 5, 36, 0x6E69616D, 0x00000000, 13);   # EntryPoint %36 "main" gid
    o = _gpu_op6(buf, o, 0x00060010, 36, 17, 1, 1, 1);           # LocalSize 1
    o = _gpu_op4(buf, o, 0x00040047, 13, 11, 28);               # gid BuiltIn
    o = _gpu_op4(buf, o, 0x00040047, 14, 33, 0); o = _gpu_op4(buf, o, 0x00040047, 14, 34, 0);
    o = _gpu_op4(buf, o, 0x00040047, 15, 33, 1); o = _gpu_op4(buf, o, 0x00040047, 15, 34, 0);
    o = _gpu_op2(buf, o, 0x00020013, 2); o = _gpu_op3(buf, o, 0x00030021, 3, 2);
    o = _gpu_op4(buf, o, 0x00040015, 4, 32, 0); o = _gpu_op4(buf, o, 0x00040017, 5, 4, 3);
    o = _gpu_op4(buf, o, 0x00040020, 6, 1, 5); o = _gpu_op3(buf, o, 0x00030016, 7, 64);
    o = _gpu_op3(buf, o, 0x0003001D, 8, 7); o = _gpu_op3(buf, o, 0x0003001E, 9, 8);
    o = _gpu_op4(buf, o, 0x00040020, 10, 12, 9); o = _gpu_op4(buf, o, 0x00040020, 11, 12, 7);
    o = _gpu_op4(buf, o, 0x00040015, 12, 32, 1);               # %12 signed int (ConvertFToS/ldexp)
    o = _gpu_op4(buf, o, 0x0004003B, 6, 13, 1);
    o = _gpu_op4(buf, o, 0x0004003B, 10, 14, 12); o = _gpu_op4(buf, o, 0x0004003B, 10, 15, 12);
    o = _gpu_op4(buf, o, 0x0004002B, 4, 16, 0);               # %16 uint 0
    o = _gpu_ecf(buf, o, 17, 0x3FF71547652B82FE);             # LOG2E
    o = _gpu_ecf(buf, o, 18, 0x3FE62E42FEFA39EF);             # LN2
    o = _gpu_ecf(buf, o, 19, 0x4338000000000000);             # MAGIC = 1.5*2^52
    o = _gpu_ecf(buf, o, 20, 0x3E927E4FB7789F5C);             # c10 = 1/10!
    o = _gpu_ecf(buf, o, 21, 0x3EC71DE3A556C734); o = _gpu_ecf(buf, o, 22, 0x3EFA01A01A01A01A);
    o = _gpu_ecf(buf, o, 23, 0x3F2A01A01A01A01A); o = _gpu_ecf(buf, o, 24, 0x3F56C16C16C16C17);
    o = _gpu_ecf(buf, o, 25, 0x3F81111111111111); o = _gpu_ecf(buf, o, 26, 0x3FA5555555555555);
    o = _gpu_ecf(buf, o, 27, 0x3FC5555555555555); o = _gpu_ecf(buf, o, 28, 0x3FE0000000000000);
    o = _gpu_ecf(buf, o, 29, 0x3FF0000000000000); o = _gpu_ecf(buf, o, 30, 0x3FF0000000000000);
    o = _gpu_ecf(buf, o, 31, cbits);                          # %31 gelu c
    o = _gpu_ecf(buf, o, 32, abits);                          # %32 gelu a
    o = _gpu_ecf(buf, o, 33, 0x3FE0000000000000);             # %33 half
    o = _gpu_ecf(buf, o, 34, 0x3FF0000000000000);             # %34 one
    o = _gpu_ecf(buf, o, 35, 0xBFF0000000000000);             # %35 neg1
    o = _gpu_op5(buf, o, 0x00050036, 2, 36, 0, 3); o = _gpu_op2(buf, o, 0x000200F8, 37);
    o = _gpu_op4(buf, o, 0x0004003D, 5, 38, 13);             # gid
    o = _gpu_op5(buf, o, 0x00050051, 4, 39, 38, 0);          # idx
    o = _gpu_op6(buf, o, 0x00060041, 11, 40, 14, 16, 39);    # &x[idx]
    o = _gpu_op4(buf, o, 0x0004003D, 7, 41, 40);             # xv
    o = _gpu_op5(buf, o, 0x00050085, 7, 42, 41, 41);         # x2
    o = _gpu_op5(buf, o, 0x00050085, 7, 43, 42, 41);         # x3
    o = _gpu_op5(buf, o, 0x00050085, 7, 44, 32, 43);         # a*x3
    o = _gpu_op5(buf, o, 0x00050081, 7, 45, 41, 44);         # x + a*x3
    o = _gpu_op5(buf, o, 0x00050085, 7, 46, 31, 45);         # inner = c*(...)
    var st[16]; store64(&st, 47);
    o = _gpu_emit_exp(buf, o, 46, &st);                      # ex = exp(inner)
    var ex = load64(&st + 8); var nid = load64(&st);
    var negi = nid; nid = nid + 1; o = _gpu_op5(buf, o, 0x00050085, 7, negi, 46, 35);  # -inner
    store64(&st, nid);
    o = _gpu_emit_exp(buf, o, negi, &st);                    # enx = exp(-inner)
    var enx = load64(&st + 8); nid = load64(&st);
    var num = nid; nid = nid + 1; o = _gpu_op5(buf, o, 0x00050083, 7, num, ex, enx);   # ex-enx
    var den = nid; nid = nid + 1; o = _gpu_op5(buf, o, 0x00050081, 7, den, ex, enx);   # ex+enx
    var t = nid; nid = nid + 1;   o = _gpu_op5(buf, o, 0x00050088, 7, t, num, den);    # tanh = num/den
    var hx = nid; nid = nid + 1;  o = _gpu_op5(buf, o, 0x00050085, 7, hx, 33, 41);     # 0.5*x
    var ot = nid; nid = nid + 1;  o = _gpu_op5(buf, o, 0x00050081, 7, ot, 34, t);      # 1 + tanh
    var yv = nid; nid = nid + 1;  o = _gpu_op5(buf, o, 0x00050085, 7, yv, hx, ot);     # y
    var yp = nid; nid = nid + 1;  o = _gpu_op6(buf, o, 0x00060041, 11, yp, 15, 16, 39);# &y[idx]
    o = _gpu_op3(buf, o, 0x0003003E, yp, yv);               # y[idx] = yv
    o = _gpu_op2(buf, o, 0x000100FD, 0x00010038);
    store32(buf + bound_off, nid);
    return o;
}

# Get (compile+cache) the GELU kernel (one fixed kernel; key kind=4). 0 = unavailable.
fn _gpu_get_gelu(): i64 {
    var key = 4 << 56;
    var c = _gpu_cache_get(key);
    if (c == (0 - 1)) { return 0; }
    if (c != 0) { return c; }
    var spv[8192];
    var nbytes = _gpu_build_gelu(&spv);
    var shmod = gpu_shader_module_create_spirv(_gpu_ctx, &spv, nbytes);
    if (shmod == 0) { _gpu_cache_put(key, 0 - 1); return 0; }
    _gpu_cache_put(key, shmod);
    return shmod;
}

# GPU forward GELU: y[0..n) = gelu(x[0..n)), elementwise. Returns 0 on success, -1 = use CPU.
# TOLERANCE (~1e-13 vs CPU gelu_fwd), NOT bit-exact — gated by g_gpu_tc, never plain g_gpu.
fn gpu_gelu_fwd(x, y, n): i64 {
    if (_gpu_init() == 0) { return 0 - 1; }
    if (n <= 0) { return 0 - 1; }
    if (n > MABDA_MAX_DISPATCH_DIM) { return 0 - 1; }
    if ((n * 8) > GPU_BO_MAX()) { return 0 - 1; }
    var sh = _gpu_get_gelu();
    if (sh == 0) { return 0 - 1; }
    var i = 0;
    while (i < n) { store64(_gpu_xm + i * 8, load64(x + i * 8)); i = i + 1; }
    var bp[40];
    store64(&bp + 0, 2);
    store64(&bp + 8, _gpu_xh); store64(&bp + 16, _GPU_XVA());
    store64(&bp + 24, _gpu_yh); store64(&bp + 32, _GPU_YVA());
    if (gpu_compute_dispatch(_gpu_ctx, sh, n, 1, 1, &bp) != 0) { return 0 - 1; }
    i = 0;
    while (i < n) { store64(y + i * 8, load64(_gpu_ym + i * 8)); i = i + 1; }
    _gpu_gelu_count = _gpu_gelu_count + 1;
    return 0;
}

# GELU backward kernel (1.8.6): bindings x=0(%14) dy=1(%15) dx=2(%16). dx = dy·gelu'(x),
# gelu'(x) = 0.5(1+t) + 0.5·x·(1−t²)·c(1+3a·x²), t = tanh(c(x+a·x³)) — EXACTLY ops.cyr gelu_bwd.
# Reuses _gpu_emit_exp (exp consts MUST stay at %17–30), so the 3rd binding pushes uint0 to %37,
# 3a to %36, fn to %40. TOLERANCE (in-shader exp). One thread per element (grid n).
fn _gpu_build_gelu_bwd(buf): i64 {
    var cbits = f64_sqrt(f64_div(f64_from(2), F64_PI));
    var abits = f64_div(f64_from(44715), f64_from(1000000));
    var threea = f64_mul(f64_from(3), abits);
    var o = _gpu_op3(buf, 0, 0x07230203, 0x00010300, 0x00000000);
    var bound_off = o; o = _gpu_op2(buf, o, 0x00000000, 0x00000000);
    o = _gpu_op2(buf, o, 0x00020011, 1); o = _gpu_op2(buf, o, 0x00020011, 10);
    o = _gpu_op3(buf, o, 0x0006000B, 1, 0x4C534C47);
    store32(buf + o, 0x6474732E); store32(buf + o + 4, 0x3035342E); store32(buf + o + 8, 0x00000000); o = o + 12;
    o = _gpu_op3(buf, o, 0x0003000E, 0, 1);
    o = _gpu_op6(buf, o, 0x0006000F, 5, 40, 0x6E69616D, 0x00000000, 13);
    o = _gpu_op6(buf, o, 0x00060010, 40, 17, 1, 1, 1);
    o = _gpu_op4(buf, o, 0x00040047, 13, 11, 28);
    o = _gpu_op4(buf, o, 0x00040047, 14, 33, 0); o = _gpu_op4(buf, o, 0x00040047, 14, 34, 0);
    o = _gpu_op4(buf, o, 0x00040047, 15, 33, 1); o = _gpu_op4(buf, o, 0x00040047, 15, 34, 0);
    o = _gpu_op4(buf, o, 0x00040047, 16, 33, 2); o = _gpu_op4(buf, o, 0x00040047, 16, 34, 0);
    o = _gpu_op2(buf, o, 0x00020013, 2); o = _gpu_op3(buf, o, 0x00030021, 3, 2);
    o = _gpu_op4(buf, o, 0x00040015, 4, 32, 0); o = _gpu_op4(buf, o, 0x00040017, 5, 4, 3);
    o = _gpu_op4(buf, o, 0x00040020, 6, 1, 5); o = _gpu_op3(buf, o, 0x00030016, 7, 64);
    o = _gpu_op3(buf, o, 0x0003001D, 8, 7); o = _gpu_op3(buf, o, 0x0003001E, 9, 8);
    o = _gpu_op4(buf, o, 0x00040020, 10, 12, 9); o = _gpu_op4(buf, o, 0x00040020, 11, 12, 7);
    o = _gpu_op4(buf, o, 0x00040015, 12, 32, 1);
    o = _gpu_op4(buf, o, 0x0004003B, 6, 13, 1);
    o = _gpu_op4(buf, o, 0x0004003B, 10, 14, 12); o = _gpu_op4(buf, o, 0x0004003B, 10, 15, 12);
    o = _gpu_op4(buf, o, 0x0004003B, 10, 16, 12);
    o = _gpu_ecf(buf, o, 17, 0x3FF71547652B82FE); o = _gpu_ecf(buf, o, 18, 0x3FE62E42FEFA39EF);
    o = _gpu_ecf(buf, o, 19, 0x4338000000000000); o = _gpu_ecf(buf, o, 20, 0x3E927E4FB7789F5C);
    o = _gpu_ecf(buf, o, 21, 0x3EC71DE3A556C734); o = _gpu_ecf(buf, o, 22, 0x3EFA01A01A01A01A);
    o = _gpu_ecf(buf, o, 23, 0x3F2A01A01A01A01A); o = _gpu_ecf(buf, o, 24, 0x3F56C16C16C16C17);
    o = _gpu_ecf(buf, o, 25, 0x3F81111111111111); o = _gpu_ecf(buf, o, 26, 0x3FA5555555555555);
    o = _gpu_ecf(buf, o, 27, 0x3FC5555555555555); o = _gpu_ecf(buf, o, 28, 0x3FE0000000000000);
    o = _gpu_ecf(buf, o, 29, 0x3FF0000000000000); o = _gpu_ecf(buf, o, 30, 0x3FF0000000000000);
    o = _gpu_ecf(buf, o, 31, cbits); o = _gpu_ecf(buf, o, 32, abits);
    o = _gpu_ecf(buf, o, 33, 0x3FE0000000000000); o = _gpu_ecf(buf, o, 34, 0x3FF0000000000000);
    o = _gpu_ecf(buf, o, 35, 0xBFF0000000000000); o = _gpu_ecf(buf, o, 36, threea);
    o = _gpu_op4(buf, o, 0x0004002B, 4, 37, 0);             # %37 uint 0 (member index)
    o = _gpu_op5(buf, o, 0x00050036, 2, 40, 0, 3); o = _gpu_op2(buf, o, 0x000200F8, 41);
    o = _gpu_op4(buf, o, 0x0004003D, 5, 42, 13);            # gid
    o = _gpu_op5(buf, o, 0x00050051, 4, 43, 42, 0);         # idx
    o = _gpu_op6(buf, o, 0x00060041, 11, 44, 14, 37, 43); o = _gpu_op4(buf, o, 0x0004003D, 7, 45, 44);  # xv
    o = _gpu_op5(buf, o, 0x00050085, 7, 46, 45, 45);        # x2
    o = _gpu_op5(buf, o, 0x00050085, 7, 47, 46, 45);        # x3
    o = _gpu_op5(buf, o, 0x00050085, 7, 48, 32, 47);        # a*x3
    o = _gpu_op5(buf, o, 0x00050081, 7, 49, 45, 48);        # x + a*x3
    o = _gpu_op5(buf, o, 0x00050085, 7, 50, 31, 49);        # inner = c*(...)
    var st[16]; store64(&st, 51);
    o = _gpu_emit_exp(buf, o, 50, &st);
    var ex = load64(&st + 8); var nid = load64(&st);
    var negi = nid; nid = nid + 1; o = _gpu_op5(buf, o, 0x00050085, 7, negi, 50, 35);   # -inner
    store64(&st, nid);
    o = _gpu_emit_exp(buf, o, negi, &st);
    var enx = load64(&st + 8); nid = load64(&st);
    var num = nid; nid = nid + 1; o = _gpu_op5(buf, o, 0x00050083, 7, num, ex, enx);
    var den = nid; nid = nid + 1; o = _gpu_op5(buf, o, 0x00050081, 7, den, ex, enx);
    var t = nid; nid = nid + 1; o = _gpu_op5(buf, o, 0x00050088, 7, t, num, den);       # tanh
    var tt = nid; nid = nid + 1; o = _gpu_op5(buf, o, 0x00050085, 7, tt, t, t);
    var sech2 = nid; nid = nid + 1; o = _gpu_op5(buf, o, 0x00050083, 7, sech2, 34, tt); # 1 - t²
    var t3a = nid; nid = nid + 1; o = _gpu_op5(buf, o, 0x00050085, 7, t3a, 36, 46);     # 3a·x²
    var inn1 = nid; nid = nid + 1; o = _gpu_op5(buf, o, 0x00050081, 7, inn1, 34, t3a);  # 1 + 3a·x²
    var dinr = nid; nid = nid + 1; o = _gpu_op5(buf, o, 0x00050085, 7, dinr, 31, inn1); # c·(...)
    var ot = nid; nid = nid + 1; o = _gpu_op5(buf, o, 0x00050081, 7, ot, 34, t);        # 1 + t
    var tm1 = nid; nid = nid + 1; o = _gpu_op5(buf, o, 0x00050085, 7, tm1, 33, ot);     # 0.5(1+t)
    var hx = nid; nid = nid + 1; o = _gpu_op5(buf, o, 0x00050085, 7, hx, 33, 45);       # 0.5·x
    var sd = nid; nid = nid + 1; o = _gpu_op5(buf, o, 0x00050085, 7, sd, sech2, dinr);
    var tm2 = nid; nid = nid + 1; o = _gpu_op5(buf, o, 0x00050085, 7, tm2, hx, sd);
    var grad = nid; nid = nid + 1; o = _gpu_op5(buf, o, 0x00050081, 7, grad, tm1, tm2);
    var dyp = nid; nid = nid + 1; o = _gpu_op6(buf, o, 0x00060041, 11, dyp, 15, 37, 43);
    var dyv = nid; nid = nid + 1; o = _gpu_op4(buf, o, 0x0004003D, 7, dyv, dyp);
    var dxv = nid; nid = nid + 1; o = _gpu_op5(buf, o, 0x00050085, 7, dxv, dyv, grad);  # dy·grad
    var dxp = nid; nid = nid + 1; o = _gpu_op6(buf, o, 0x00060041, 11, dxp, 16, 37, 43);
    o = _gpu_op3(buf, o, 0x0003003E, dxp, dxv);
    o = _gpu_op2(buf, o, 0x000100FD, 0x00010038);
    store32(buf + bound_off, nid);
    return o;
}

# Compile+cache the GELU backward kernel (kind=13). 0 = unavailable.
fn _gpu_get_gelu_bwd(): i64 {
    var key = 13 << 56;
    var c = _gpu_cache_get(key);
    if (c == (0 - 1)) { return 0; }
    if (c != 0) { return c; }
    var spv[8192];
    var nbytes = _gpu_build_gelu_bwd(&spv);
    var shmod = gpu_shader_module_create_spirv(_gpu_ctx, &spv, nbytes);
    if (shmod == 0) { _gpu_cache_put(key, 0 - 1); return 0; }
    _gpu_cache_put(key, shmod);
    return shmod;
}

# GPU GELU backward: dx[0..n) = dy·gelu'(x), elementwise. Returns 0 = ran, -1 = use CPU.
# TOLERANCE (in-shader exp) → gated by g_gpu_tc. Buffers: x→x, dy→W, dx→y.
fn gpu_gelu_bwd(x, dy, dx, n): i64 {
    if (_gpu_init() == 0) { return 0 - 1; }
    if (n <= 0) { return 0 - 1; }
    if (n > MABDA_MAX_DISPATCH_DIM) { return 0 - 1; }
    if ((n * 8) > GPU_BO_MAX()) { return 0 - 1; }
    var sh = _gpu_get_gelu_bwd();
    if (sh == 0) { return 0 - 1; }
    var i = 0;
    while (i < n) { store64(_gpu_xm + i*8, load64(x + i*8)); i = i + 1; }
    i = 0; while (i < n) { store64(_gpu_wm + i*8, load64(dy + i*8)); i = i + 1; }
    var bp[56];
    store64(&bp+0, 3);
    store64(&bp+8, _gpu_xh); store64(&bp+16, _GPU_XVA());
    store64(&bp+24, _gpu_wh); store64(&bp+32, _GPU_WVA());
    store64(&bp+40, _gpu_yh); store64(&bp+48, _GPU_YVA());
    if (gpu_compute_dispatch(_gpu_ctx, sh, n, 1, 1, &bp) != 0) { return 0 - 1; }
    i = 0; while (i < n) { store64(dx + i*8, load64(_gpu_ym + i*8)); i = i + 1; }
    _gpu_gelu_count = _gpu_gelu_count + 1;
    return 0;
}

# Get (compile+cache) the transposed head tile for (K, N, k0). Key kind=5. 0 = unavailable.
fn _gpu_get_tile_t(K, N, k0): i64 {
    var key = (5 << 56) | (K << 28) | (N << 14) | k0;
    var c = _gpu_cache_get(key);
    if (c == (0 - 1)) { return 0; }
    if (c != 0) { return c; }
    var spv[8192];
    var nbytes = _gpu_build_tile_t(&spv, K, N, k0, GPU_TK());
    var shmod = gpu_shader_module_create_spirv(_gpu_ctx, &spv, nbytes);
    if (shmod == 0) { _gpu_cache_put(key, 0 - 1); return 0; }
    _gpu_cache_put(key, shmod);
    return shmod;
}

# GPU LM head: logits(T,V) = f(T,C) · tokemb(V,C)ᵀ (tied embedding, contracted on C). Returns
# 0 on success, -1 = use CPU. TOLERANCE (sequential vs the CPU head's 4-lane-tree dot) — gated
# by g_gpu_tc, never plain g_gpu. Reuses the matmul k-tiling with the transposed-weight kernel.
fn gpu_head_fwd(f, emb, logits, T, V, C): i64 {
    if (_gpu_init() == 0) { return 0 - 1; }
    var TK = GPU_TK();
    if (C <= 0) { return 0 - 1; }
    if ((C % TK) != 0) { return 0 - 1; }
    if ((T * V) <= 0) { return 0 - 1; }
    if ((T * V) > MABDA_MAX_DISPATCH_DIM) { return 0 - 1; }
    if ((T * C * 8) > GPU_BO_MAX()) { return 0 - 1; }
    if ((V * C * 8) > GPU_BO_MAX()) { return 0 - 1; }
    if ((T * V * 8) > GPU_BO_MAX()) { return 0 - 1; }
    # upload f → x buffer, emb → W buffer; pre-fill y (logits) with 0 (no bias)
    var i = 0; var nf = T * C;
    while (i < nf) { store64(_gpu_xm + i * 8, load64(f + i * 8)); i = i + 1; }
    i = 0; var ne = V * C;
    while (i < ne) { store64(_gpu_wm + i * 8, load64(emb + i * 8)); i = i + 1; }
    var MN = T * V;
    i = 0;
    while (i < MN) { store64(_gpu_ym + i * 8, f64_from(0)); i = i + 1; }
    var k0 = 0;
    while (k0 < C) {
        var sh = _gpu_get_tile_t(C, V, k0);
        if (sh == 0) { return 0 - 1; }
        var bp[56];
        store64(&bp + 0, 3);
        store64(&bp + 8, _gpu_xh);  store64(&bp + 16, _GPU_XVA());
        store64(&bp + 24, _gpu_wh); store64(&bp + 32, _GPU_WVA());
        store64(&bp + 40, _gpu_yh); store64(&bp + 48, _GPU_YVA());
        if (gpu_compute_dispatch(_gpu_ctx, sh, MN, 1, 1, &bp) != 0) { return 0 - 1; }
        k0 = k0 + TK;
    }
    i = 0;
    while (i < MN) { store64(logits + i * 8, load64(_gpu_ym + i * 8)); i = i + 1; }
    _gpu_head_count = _gpu_head_count + 1;
    return 0;
}

# ===========================================================================
# 1.8.7 — linear backward on GPU (the highest-FLOP backward op). dx = dy·Wᵀ (reuses the
# transposed tile _gpu_build_tile_t, contract N → TOLERANCE, sequential vs CPU 4-lane-tree),
# dW += xᵀ·dy (NEW _gpu_build_tile_dw, contract M, RMW onto the pre-uploaded dW → bit-exact
# accumulation), db += colsum_m(dy) on the host. The whole op rides g_gpu_tc (dx forces tolerance).
# ===========================================================================

# dW tile (contract M): dW[k,n] += Σ_{m∈tile} x[m·K+k]·dy[m·N+n]. Clone of _gpu_build_tile, but
# both operands stride by their row width over the contracted m (x +K, dy +N), write index k·N+n.
# consts %16=0 %17=N %18=K %19=m0·K %20=m0·N. RMW (host pre-fills dW = caller's running grad).
fn _gpu_build_tile_dw(buf, K, N, m0, TK): i64 {
    var m0K = m0 * K; var m0N = m0 * N;
    var o = _gpu_op3(buf, 0, 0x07230203, 0x00010300, 0x00000000);
    var bound_off = o;
    o = _gpu_op2(buf, o, 0x00000000, 0x00000000);
    o = _gpu_op2(buf, o, 0x00020011, 1); o = _gpu_op2(buf, o, 0x00020011, 10);
    o = _gpu_op3(buf, o, 0x0003000E, 0, 1);
    o = _gpu_op6(buf, o, 0x0006000F, 5, 22, 0x6E69616D, 0x00000000, 11);
    o = _gpu_op6(buf, o, 0x00060010, 22, 17, 1, 1, 1);
    o = _gpu_op4(buf, o, 0x00040047, 11, 11, 28);
    o = _gpu_op4(buf, o, 0x00040047, 12, 33, 0); o = _gpu_op4(buf, o, 0x00040047, 12, 34, 0);
    o = _gpu_op4(buf, o, 0x00040047, 13, 33, 1); o = _gpu_op4(buf, o, 0x00040047, 13, 34, 0);
    o = _gpu_op4(buf, o, 0x00040047, 14, 33, 2); o = _gpu_op4(buf, o, 0x00040047, 14, 34, 0);
    o = _gpu_op2(buf, o, 0x00020013, 1); o = _gpu_op3(buf, o, 0x00030021, 2, 1);
    o = _gpu_op4(buf, o, 0x00040015, 3, 32, 0); o = _gpu_op4(buf, o, 0x00040017, 4, 3, 3);
    o = _gpu_op4(buf, o, 0x00040020, 5, 1, 4); o = _gpu_op3(buf, o, 0x00030016, 6, 64);
    o = _gpu_op3(buf, o, 0x0003001D, 7, 6); o = _gpu_op3(buf, o, 0x0003001E, 8, 7);
    o = _gpu_op4(buf, o, 0x00040020, 9, 12, 8); o = _gpu_op4(buf, o, 0x00040020, 10, 12, 6);
    o = _gpu_op4(buf, o, 0x0004002B, 3, 16, 0); o = _gpu_op4(buf, o, 0x0004002B, 3, 17, N);
    o = _gpu_op4(buf, o, 0x0004002B, 3, 18, K); o = _gpu_op4(buf, o, 0x0004002B, 3, 19, m0K);
    o = _gpu_op4(buf, o, 0x0004002B, 3, 20, m0N);
    o = _gpu_op4(buf, o, 0x0004003B, 5, 11, 1);
    o = _gpu_op4(buf, o, 0x0004003B, 9, 12, 12); o = _gpu_op4(buf, o, 0x0004003B, 9, 13, 12);
    o = _gpu_op4(buf, o, 0x0004003B, 9, 14, 12);
    o = _gpu_op5(buf, o, 0x00050036, 1, 22, 0, 2); o = _gpu_op2(buf, o, 0x000200F8, 23);
    o = _gpu_op4(buf, o, 0x0004003D, 4, 24, 11);
    o = _gpu_op5(buf, o, 0x00050051, 3, 25, 24, 0);            # idx
    o = _gpu_op5(buf, o, 0x00050086, 3, 26, 25, 17);          # k = idx / N
    o = _gpu_op5(buf, o, 0x00050089, 3, 27, 25, 17);          # n = idx % N
    o = _gpu_op5(buf, o, 0x00050080, 3, 28, 26, 19);          # xi = k + m0·K
    o = _gpu_op5(buf, o, 0x00050080, 3, 29, 27, 20);          # wi = n + m0·N
    o = _gpu_op6(buf, o, 0x00060041, 10, 30, 14, 16, 25);     # &dW[idx]
    o = _gpu_op4(buf, o, 0x0004003D, 6, 31, 30);              # acc = dW[idx] (RMW base)
    var xi = 28; var wi = 29; var acc = 31; var nid = 32;
    var j = 0;
    while (j < TK) {
        var ax = nid; nid = nid + 1; o = _gpu_op6(buf, o, 0x00060041, 10, ax, 12, 16, xi);
        var vx = nid; nid = nid + 1; o = _gpu_op4(buf, o, 0x0004003D, 6, vx, ax);
        var aw = nid; nid = nid + 1; o = _gpu_op6(buf, o, 0x00060041, 10, aw, 13, 16, wi);
        var vw = nid; nid = nid + 1; o = _gpu_op4(buf, o, 0x0004003D, 6, vw, aw);
        var prod = nid; nid = nid + 1; o = _gpu_op5(buf, o, 0x00050085, 6, prod, vx, vw);
        var accn = nid; nid = nid + 1; o = _gpu_op5(buf, o, 0x00050081, 6, accn, acc, prod);
        acc = accn;
        if (j < TK - 1) {
            var xin = nid; nid = nid + 1; o = _gpu_op5(buf, o, 0x00050080, 3, xin, xi, 18);  # xi += K
            var win = nid; nid = nid + 1; o = _gpu_op5(buf, o, 0x00050080, 3, win, wi, 17);  # wi += N
            xi = xin; wi = win;
        }
        j = j + 1;
    }
    o = _gpu_op3(buf, o, 0x0003003E, 30, acc);               # dW[idx] = acc
    o = _gpu_op2(buf, o, 0x000100FD, 0x00010038);
    store32(buf + bound_off, nid);
    return o;
}

# Compile+cache the dW tile for (K, N, m0). Key kind=10. 0 = unavailable.
fn _gpu_get_tile_dw(K, N, m0): i64 {
    var key = (10 << 56) | (K << 28) | (N << 14) | m0;
    var c = _gpu_cache_get(key);
    if (c == (0 - 1)) { return 0; }
    if (c != 0) { return c; }
    var spv[8192];
    var nbytes = _gpu_build_tile_dw(&spv, K, N, m0, GPU_TK());
    var shmod = gpu_shader_module_create_spirv(_gpu_ctx, &spv, nbytes);
    if (shmod == 0) { _gpu_cache_put(key, 0 - 1); return 0; }
    _gpu_cache_put(key, shmod);
    return shmod;
}

# GPU linear backward: dx(M,K)=dy·Wᵀ, dW(K,N)+=xᵀ·dy, db(N)+=colsum(dy). Returns 0 = ran, -1 = CPU.
# TOLERANCE (dx's sequential reduction vs the CPU 4-lane-tree) → gated by g_gpu_tc. dW/db are
# bit-exact in arithmetic (sequential m; dW RMW onto the caller's running grad). Buffers reused
# per phase: dx → (dy→x, W→W, dx←y); dW → (x→x, dy→W, dW↔y RMW); db on host.
fn gpu_linear_bwd(x, W, dy, dx, dW, db, M, K, N): i64 {
    if (_gpu_init() == 0) { return 0 - 1; }
    var TK = GPU_TK();
    if (M <= 0) { return 0 - 1; }
    if ((N % TK) != 0) { return 0 - 1; }            # dx tiles over N
    if ((M % TK) != 0) { return 0 - 1; }            # dW tiles over M
    if ((M * K) > MABDA_MAX_DISPATCH_DIM) { return 0 - 1; }
    if ((K * N) > MABDA_MAX_DISPATCH_DIM) { return 0 - 1; }
    var mk = M * K; var mn = M * N; var kn = K * N;
    if ((mn * 8) > GPU_BO_MAX()) { return 0 - 1; }
    if ((kn * 8) > GPU_BO_MAX()) { return 0 - 1; }
    if ((mk * 8) > GPU_BO_MAX()) { return 0 - 1; }
    # ---- dx = dy·Wᵀ (tile_t: contract N, output M×K), RMW from 0 ----
    var i = 0;
    while (i < mn) { store64(_gpu_xm + i*8, load64(dy + i*8)); i = i + 1; }    # dy → x-buf
    i = 0; while (i < kn) { store64(_gpu_wm + i*8, load64(W + i*8)); i = i + 1; }   # W → W-buf
    i = 0; while (i < mk) { store64(_gpu_ym + i*8, f64_from(0)); i = i + 1; }  # dx ← 0
    var k0 = 0;
    while (k0 < N) {
        var sh = _gpu_get_tile_t(N, K, k0);          # contract = N, output cols = K
        if (sh == 0) { return 0 - 1; }
        var bp[56]; store64(&bp+0, 3);
        store64(&bp+8, _gpu_xh); store64(&bp+16, _GPU_XVA());
        store64(&bp+24, _gpu_wh); store64(&bp+32, _GPU_WVA());
        store64(&bp+40, _gpu_yh); store64(&bp+48, _GPU_YVA());
        if (gpu_compute_dispatch(_gpu_ctx, sh, mk, 1, 1, &bp) != 0) { return 0 - 1; }
        k0 = k0 + TK;
    }
    i = 0; while (i < mk) { store64(dx + i*8, load64(_gpu_ym + i*8)); i = i + 1; }
    # ---- dW += xᵀ·dy (tile_dw: contract M, output K×N), RMW onto caller's dW ----
    i = 0; while (i < mk) { store64(_gpu_xm + i*8, load64(x + i*8)); i = i + 1; }   # x → x-buf
    i = 0; while (i < mn) { store64(_gpu_wm + i*8, load64(dy + i*8)); i = i + 1; }  # dy → W-buf
    i = 0; while (i < kn) { store64(_gpu_ym + i*8, load64(dW + i*8)); i = i + 1; }  # dW → y-buf (RMW base)
    var m0 = 0;
    while (m0 < M) {
        var sh2 = _gpu_get_tile_dw(K, N, m0);
        if (sh2 == 0) { return 0 - 1; }
        var bp2[56]; store64(&bp2+0, 3);
        store64(&bp2+8, _gpu_xh); store64(&bp2+16, _GPU_XVA());
        store64(&bp2+24, _gpu_wh); store64(&bp2+32, _GPU_WVA());
        store64(&bp2+40, _gpu_yh); store64(&bp2+48, _GPU_YVA());
        if (gpu_compute_dispatch(_gpu_ctx, sh2, kn, 1, 1, &bp2) != 0) { return 0 - 1; }
        m0 = m0 + TK;
    }
    i = 0; while (i < kn) { store64(dW + i*8, load64(_gpu_ym + i*8)); i = i + 1; }
    # ---- db += colsum_m(dy) on host (bit-exact, matches CPU sequential m) ----
    if (db != 0) {
        var nb = 0;
        while (nb < N) {
            var accb = f64_from(0); var mm = 0;
            while (mm < M) { accb = f64_add(accb, load64(dy + (mm*N + nb)*8)); mm = mm + 1; }
            store64(db + nb*8, f64_add(load64(db + nb*8), accb));
            nb = nb + 1;
        }
    }
    _gpu_linbwd_count = _gpu_linbwd_count + 1;
    return 0;
}

# ===========================================================================
# 1.8.8 — LM-head backward on GPU, BIT-EXACT (the tied-embedding gradients). The CPU head_bwd is
# pure-scalar sequential (NOT the SIMD-tree forward head), so sequential GPU reductions match it
# bit-for-bit → plain --gpu, keeps byte-identity. Both phases reuse proven tiles:
#   D_f[t,c]    = Σ_v D_logits[t,v]·emb[v,c]   → _gpu_build_tile (K=V, N=C, grid T·C, zero-init)
#   gemb[v,c]  += Σ_t D_logits[t,v]·A_f[t,c]   → _gpu_build_tile_dw (K=V, N=C, grid V·C, RMW onto gemb)
# ===========================================================================

# GPU LM-head backward: D_f(T,C) + gemb(V,C) from D_logits(T,V), emb(V,C), A_f(T,C). Returns 0 =
# ran, -1 = use CPU. BIT-EXACT → gated by g_gpu. Buffers reused per phase (D_logits→x both phases).
fn gpu_head_bwd(D_logits, emb, A_f, D_f, gemb, T, V, C): i64 {
    if (_gpu_init() == 0) { return 0 - 1; }
    var TK = GPU_TK();
    if (V <= 0) { return 0 - 1; }
    if ((T % TK) != 0) { return 0 - 1; }            # gemb tiles over T (1.9.0: D_f tail-tiles V for any vocab)
    if ((T * C) > MABDA_MAX_DISPATCH_DIM) { return 0 - 1; }
    if ((V * C) > MABDA_MAX_DISPATCH_DIM) { return 0 - 1; }
    var tv = T * V; var vc = V * C; var tc = T * C;
    if ((tv * 8) > GPU_BO_MAX()) { return 0 - 1; }
    if ((vc * 8) > GPU_BO_MAX()) { return 0 - 1; }
    if ((tc * 8) > GPU_BO_MAX()) { return 0 - 1; }
    # ---- D_f = D_logits·emb (forward tile, K=V N=C, grid T·C, RMW from 0) ----
    var i = 0;
    while (i < tv) { store64(_gpu_xm + i*8, load64(D_logits + i*8)); i = i + 1; }
    i = 0; while (i < vc) { store64(_gpu_wm + i*8, load64(emb + i*8)); i = i + 1; }
    i = 0; while (i < tc) { store64(_gpu_ym + i*8, f64_from(0)); i = i + 1; }
    var k0 = 0;
    while (k0 < V) {
        var tkv = TK; if (V - k0 < TK) { tkv = V - k0; }   # short final tile when V%16≠0
        var sh = 0;
        if (tkv == TK) { sh = _gpu_get_tile(V, C, k0); } else { sh = _gpu_get_tile_n(V, C, k0, tkv); }
        if (sh == 0) { return 0 - 1; }
        var bp[56]; store64(&bp+0, 3);
        store64(&bp+8, _gpu_xh); store64(&bp+16, _GPU_XVA());
        store64(&bp+24, _gpu_wh); store64(&bp+32, _GPU_WVA());
        store64(&bp+40, _gpu_yh); store64(&bp+48, _GPU_YVA());
        if (gpu_compute_dispatch(_gpu_ctx, sh, tc, 1, 1, &bp) != 0) { return 0 - 1; }
        k0 = k0 + tkv;
    }
    i = 0; while (i < tc) { store64(D_f + i*8, load64(_gpu_ym + i*8)); i = i + 1; }
    # ---- gemb += D_logitsᵀ·A_f (tile_dw, K=V N=C, grid V·C). CPU head_bwd does gemb = seed +
    # (Σ_t from 0), NOT RMW-from-seed (unlike linear_bwd's dW) — so compute the PURE Σ (zero-init)
    # then host-add onto the caller's gemb, matching the CPU's f64_add order bit-for-bit.
    i = 0; while (i < tv) { store64(_gpu_xm + i*8, load64(D_logits + i*8)); i = i + 1; }
    i = 0; while (i < tc) { store64(_gpu_wm + i*8, load64(A_f + i*8)); i = i + 1; }
    i = 0; while (i < vc) { store64(_gpu_ym + i*8, f64_from(0)); i = i + 1; }
    var m0 = 0;
    while (m0 < T) {
        var sh2 = _gpu_get_tile_dw(V, C, m0);
        if (sh2 == 0) { return 0 - 1; }
        var bp2[56]; store64(&bp2+0, 3);
        store64(&bp2+8, _gpu_xh); store64(&bp2+16, _GPU_XVA());
        store64(&bp2+24, _gpu_wh); store64(&bp2+32, _GPU_WVA());
        store64(&bp2+40, _gpu_yh); store64(&bp2+48, _GPU_YVA());
        if (gpu_compute_dispatch(_gpu_ctx, sh2, vc, 1, 1, &bp2) != 0) { return 0 - 1; }
        m0 = m0 + TK;
    }
    i = 0; while (i < vc) { store64(gemb + i*8, f64_add(load64(gemb + i*8), load64(_gpu_ym + i*8))); i = i + 1; }
    _gpu_headbwd_count = _gpu_headbwd_count + 1;
    return 0;
}

# ===========================================================================
# 1.8.9 — layernorm backward on GPU, BIT-EXACT (sequential reductions + sqrt/div; rstd is a
# precomputed input so NO transcendental). 3 passes (no GLSL preamble needed):
#   P1 row-reduce : Mpack[m]=Σ_i dxhat, Mpack[M+m]=Σ_i dxhat·xhat (grid M, j-tiled over C; ×invC host)
#   P3 dx         : dx = rstd·(dxhat − mdxhat − xhat·mdxhat_xhat) (grid M·C, elementwise)
#   P2 dgamma/dbeta: dgamma[i]+=Σ_m dy·xhat, dbeta[i]+=Σ_m dy (grid C, j-tiled over M, RMW-from-seed)
# Run 1→3→2 so the 7-BO pool juggles (dx→beta, then dgamma→gamma / dbeta→y reuse). xhat=(x−mean)·rstd,
# dxhat=dy·gamma. mdxhat is seed+pure-Σ (host ×invC); dgamma/dbeta are RMW-from-seed (CPU's += order).
# ===========================================================================

# P1 row-reduce: x=0(%12) dy=1(%13) gamma=2(%14) mean=3(%15) rstd=4(%16) Mpack=5(%17). grid M.
fn _gpu_build_lnbwd_red(buf, C, c0, M, TK): i64 {
    var o = _gpu_pre(buf, 6, 23);
    o = _gpu_op4(buf, o, 0x0004002B, 3, 18, 0); o = _gpu_op4(buf, o, 0x0004002B, 3, 19, C);
    o = _gpu_op4(buf, o, 0x0004002B, 3, 20, c0); o = _gpu_op4(buf, o, 0x0004002B, 3, 21, 1);
    o = _gpu_op4(buf, o, 0x0004002B, 3, 22, M);
    o = _gpu_op5(buf, o, 0x00050036, 1, 23, 0, 2); o = _gpu_op2(buf, o, 0x000200F8, 24);
    o = _gpu_op4(buf, o, 0x0004003D, 4, 25, 11);
    o = _gpu_op5(buf, o, 0x00050051, 3, 26, 25, 0);              # m
    o = _gpu_op5(buf, o, 0x00050084, 3, 27, 26, 19);            # mC
    o = _gpu_op6(buf, o, 0x00060041, 10, 28, 15, 18, 26); o = _gpu_op4(buf, o, 0x0004003D, 6, 29, 28);  # mu
    o = _gpu_op6(buf, o, 0x00060041, 10, 30, 16, 18, 26); o = _gpu_op4(buf, o, 0x0004003D, 6, 31, 30);  # rs
    o = _gpu_op6(buf, o, 0x00060041, 10, 32, 17, 18, 26); o = _gpu_op4(buf, o, 0x0004003D, 6, 33, 32);  # accg=Mpack[m]
    o = _gpu_op5(buf, o, 0x00050080, 3, 34, 26, 22);           # Mm = m+M
    o = _gpu_op6(buf, o, 0x00060041, 10, 35, 17, 18, 34);
    o = _gpu_op4(buf, o, 0x0004003D, 6, 36, 35);
    # accgx=Mpack[Mm];
    o = _gpu_op5(buf, o, 0x00050080, 3, 37, 27, 20);           # xi = mC+c0
    o = _gpu_op5(buf, o, 0x00050082, 3, 38, 26, 26);           # vz = m - m (VGPR 0; taints gi VGPR)
    o = _gpu_op5(buf, o, 0x00050080, 3, 39, 20, 38);           # gi = c0 + vz (VGPR — gamma idx)
    var xi = 37; var gi = 39; var accg = 33; var accgx = 36; var nid = 40;
    var j = 0;
    while (j < TK) {
        var xp=nid;
        nid=nid+1;
        o=_gpu_op6(buf,o,0x00060041,10,xp,12,18,xi);
        var xv=nid;
        nid=nid+1;
        o=_gpu_op4(buf,o,0x0004003D,6,xv,xp);
        var dp=nid;
        nid=nid+1;
        o=_gpu_op6(buf,o,0x00060041,10,dp,13,18,xi);
        var dv=nid;
        nid=nid+1;
        o=_gpu_op4(buf,o,0x0004003D,6,dv,dp);
        var gp=nid;
        nid=nid+1;
        o=_gpu_op6(buf,o,0x00060041,10,gp,14,18,gi);
        var gv=nid;
        nid=nid+1;
        o=_gpu_op4(buf,o,0x0004003D,6,gv,gp);
        var sb=nid;nid=nid+1; o=_gpu_op5(buf,o,0x00050083,6,sb,xv,29);
        var xh=nid;nid=nid+1; o=_gpu_op5(buf,o,0x00050085,6,xh,sb,31);
        var dx=nid;nid=nid+1; o=_gpu_op5(buf,o,0x00050085,6,dx,dv,gv);
        var ng=nid;nid=nid+1; o=_gpu_op5(buf,o,0x00050081,6,ng,accg,dx); accg=ng;
        var px=nid;nid=nid+1; o=_gpu_op5(buf,o,0x00050085,6,px,dx,xh);
        var ngx=nid;nid=nid+1; o=_gpu_op5(buf,o,0x00050081,6,ngx,accgx,px); accgx=ngx;
        if (j < TK-1) {
            var xn=nid;
            nid=nid+1;
            o=_gpu_op5(buf,o,0x00050080,3,xn,xi,21);
            xi=xn;
            var gn=nid;
            nid=nid+1;
            o=_gpu_op5(buf,o,0x00050080,3,gn,gi,21);
            gi=gn;
        }
        j = j + 1;
    }
    o = _gpu_op3(buf, o, 0x0003003E, 32, accg); o = _gpu_op3(buf, o, 0x0003003E, 35, accgx);
    o = _gpu_op2(buf, o, 0x000100FD, 0x00010038); store32(buf+12, nid); return o;
}

# P2 dgamma/dbeta: x=0(%12) dy=1(%13) mean=2(%14) rstd=3(%15) dgamma=4(%16) dbeta=5(%17). grid C.
fn _gpu_build_lnbwd_param(buf, C, m0, M, TK): i64 {
    var m0C = m0 * C;
    var o = _gpu_pre(buf, 6, 23);
    o = _gpu_op4(buf, o, 0x0004002B, 3, 18, 0); o = _gpu_op4(buf, o, 0x0004002B, 3, 19, C);
    o = _gpu_op4(buf, o, 0x0004002B, 3, 20, m0); o = _gpu_op4(buf, o, 0x0004002B, 3, 21, 1);
    o = _gpu_op4(buf, o, 0x0004002B, 3, 22, m0C);
    o = _gpu_op5(buf, o, 0x00050036, 1, 23, 0, 2); o = _gpu_op2(buf, o, 0x000200F8, 24);
    o = _gpu_op4(buf, o, 0x0004003D, 4, 25, 11);
    o = _gpu_op5(buf, o, 0x00050051, 3, 26, 25, 0);             # i (col)
    o = _gpu_op6(buf, o, 0x00060041, 10, 27, 16, 18, 26); o = _gpu_op4(buf, o, 0x0004003D, 6, 28, 27);  # accg=dgamma[i]
    o = _gpu_op6(buf, o, 0x00060041, 10, 29, 17, 18, 26); o = _gpu_op4(buf, o, 0x0004003D, 6, 30, 29);  # accb=dbeta[i]
    o = _gpu_op5(buf, o, 0x00050080, 3, 31, 22, 26);           # xi = m0C + i
    o = _gpu_op5(buf, o, 0x00050082, 3, 32, 26, 26);           # vz = i - i (VGPR 0; taints mi VGPR)
    o = _gpu_op5(buf, o, 0x00050080, 3, 33, 20, 32);           # mi = m0 + vz (VGPR — mean/rstd idx)
    var xi = 31; var mi = 33; var accg = 28; var accb = 30; var nid = 34;
    var j = 0;
    while (j < TK) {
        var xp=nid;
        nid=nid+1;
        o=_gpu_op6(buf,o,0x00060041,10,xp,12,18,xi);
        var xv=nid;
        nid=nid+1;
        o=_gpu_op4(buf,o,0x0004003D,6,xv,xp);
        var dp=nid;
        nid=nid+1;
        o=_gpu_op6(buf,o,0x00060041,10,dp,13,18,xi);
        var dv=nid;
        nid=nid+1;
        o=_gpu_op4(buf,o,0x0004003D,6,dv,dp);
        var mp=nid;
        nid=nid+1;
        o=_gpu_op6(buf,o,0x00060041,10,mp,14,18,mi);
        var mu=nid;
        nid=nid+1;
        o=_gpu_op4(buf,o,0x0004003D,6,mu,mp);
        var rp=nid;
        nid=nid+1;
        o=_gpu_op6(buf,o,0x00060041,10,rp,15,18,mi);
        var rs=nid;
        nid=nid+1;
        o=_gpu_op4(buf,o,0x0004003D,6,rs,rp);
        var sb=nid;nid=nid+1; o=_gpu_op5(buf,o,0x00050083,6,sb,xv,mu);
        var xh=nid;nid=nid+1; o=_gpu_op5(buf,o,0x00050085,6,xh,sb,rs);
        var p=nid;nid=nid+1; o=_gpu_op5(buf,o,0x00050085,6,p,dv,xh);
        var ng=nid;nid=nid+1; o=_gpu_op5(buf,o,0x00050081,6,ng,accg,p); accg=ng;
        var nb=nid;nid=nid+1; o=_gpu_op5(buf,o,0x00050081,6,nb,accb,dv); accb=nb;
        if (j < TK-1) {
            var xn=nid;
            nid=nid+1;
            o=_gpu_op5(buf,o,0x00050080,3,xn,xi,19);
            xi=xn;
            var mn=nid;
            nid=nid+1;
            o=_gpu_op5(buf,o,0x00050080,3,mn,mi,21);
            mi=mn;
        }
        j = j + 1;
    }
    o = _gpu_op3(buf, o, 0x0003003E, 27, accg); o = _gpu_op3(buf, o, 0x0003003E, 29, accb);
    o = _gpu_op2(buf, o, 0x000100FD, 0x00010038); store32(buf+12, nid); return o;
}

# P3 dx: x=0(%12) dy=1(%13) gamma=2(%14) mean=3(%15) rstd=4(%16) Mpack=5(%17) dx=6(%18). grid M·C.
fn _gpu_build_lnbwd_dx(buf, C, M): i64 {
    var o = _gpu_pre(buf, 7, 22);
    o = _gpu_op4(buf, o, 0x0004002B, 3, 19, 0); o = _gpu_op4(buf, o, 0x0004002B, 3, 20, C);
    o = _gpu_op4(buf, o, 0x0004002B, 3, 21, M);
    o = _gpu_op5(buf, o, 0x00050036, 1, 22, 0, 2); o = _gpu_op2(buf, o, 0x000200F8, 23);
    o = _gpu_op4(buf, o, 0x0004003D, 4, 24, 11);
    o = _gpu_op5(buf, o, 0x00050051, 3, 25, 24, 0);             # idx
    o = _gpu_op5(buf, o, 0x00050086, 3, 26, 25, 20);           # m = idx/C
    o = _gpu_op5(buf, o, 0x00050084, 3, 27, 26, 20);           # mC
    o = _gpu_op5(buf, o, 0x00050082, 3, 28, 25, 27);           # i = idx - mC
    o = _gpu_op6(buf, o, 0x00060041, 10, 29, 15, 19, 26); o = _gpu_op4(buf, o, 0x0004003D, 6, 30, 29);  # mu
    o = _gpu_op6(buf, o, 0x00060041, 10, 31, 16, 19, 26); o = _gpu_op4(buf, o, 0x0004003D, 6, 32, 31);  # rs
    o = _gpu_op6(buf, o, 0x00060041, 10, 33, 17, 19, 26);
    o = _gpu_op4(buf, o, 0x0004003D, 6, 34, 33);
    # mdxhat=Mpack[m];
    o = _gpu_op5(buf, o, 0x00050080, 3, 35, 26, 21);           # Mm = m+M
    o = _gpu_op6(buf, o, 0x00060041, 10, 36, 17, 19, 35); o = _gpu_op4(buf, o, 0x0004003D, 6, 37, 36);  # mdxhat_xhat
    o = _gpu_op6(buf, o, 0x00060041, 10, 38, 12, 19, 25); o = _gpu_op4(buf, o, 0x0004003D, 6, 39, 38);  # xv
    o = _gpu_op6(buf, o, 0x00060041, 10, 40, 13, 19, 25); o = _gpu_op4(buf, o, 0x0004003D, 6, 41, 40);  # dyv
    o = _gpu_op6(buf, o, 0x00060041, 10, 42, 14, 19, 28); o = _gpu_op4(buf, o, 0x0004003D, 6, 43, 42);  # gv
    o = _gpu_op5(buf, o, 0x00050083, 6, 44, 39, 30);           # xv - mu
    o = _gpu_op5(buf, o, 0x00050085, 6, 45, 44, 32);           # xhat
    o = _gpu_op5(buf, o, 0x00050085, 6, 46, 41, 43);           # dxhat = dyv*gv
    o = _gpu_op5(buf, o, 0x00050083, 6, 47, 46, 34);           # dxhat - mdxhat
    o = _gpu_op5(buf, o, 0x00050085, 6, 48, 45, 37);           # xhat*mdxhat_xhat
    o = _gpu_op5(buf, o, 0x00050083, 6, 49, 47, 48);           # inner
    o = _gpu_op5(buf, o, 0x00050085, 6, 50, 32, 49);           # dx = rs*inner
    o = _gpu_op6(buf, o, 0x00060041, 10, 51, 18, 19, 25);
    o = _gpu_op3(buf, o, 0x0003003E, 51, 50);
    o = _gpu_op2(buf, o, 0x000100FD, 0x00010038); store32(buf+12, 52); return o;
}

fn _gpu_get_lnbwd_red(C, c0, M, TK): i64 {
    var key = (11 << 56) | (C << 28) | (M << 14) | c0;
    var c = _gpu_cache_get(key); if (c == (0 - 1)) { return 0; } if (c != 0) { return c; }
    var spv[8192]; var nb = _gpu_build_lnbwd_red(&spv, C, c0, M, TK);
    var sh = gpu_shader_module_create_spirv(_gpu_ctx, &spv, nb);
    if (sh == 0) { _gpu_cache_put(key, 0 - 1); return 0; }
    _gpu_cache_put(key, sh); return sh;
}
fn _gpu_get_lnbwd_param(C, m0, M, TK): i64 {
    var key = (14 << 56) | (C << 28) | (M << 14) | m0;
    var c = _gpu_cache_get(key); if (c == (0 - 1)) { return 0; } if (c != 0) { return c; }
    var spv[8192]; var nb = _gpu_build_lnbwd_param(&spv, C, m0, M, TK);
    var sh = gpu_shader_module_create_spirv(_gpu_ctx, &spv, nb);
    if (sh == 0) { _gpu_cache_put(key, 0 - 1); return 0; }
    _gpu_cache_put(key, sh); return sh;
}
fn _gpu_get_lnbwd_dx(C, M): i64 {
    var key = (15 << 56) | (C << 14) | M;
    var c = _gpu_cache_get(key); if (c == (0 - 1)) { return 0; } if (c != 0) { return c; }
    var spv[8192]; var nb = _gpu_build_lnbwd_dx(&spv, C, M);
    var sh = gpu_shader_module_create_spirv(_gpu_ctx, &spv, nb);
    if (sh == 0) { _gpu_cache_put(key, 0 - 1); return 0; }
    _gpu_cache_put(key, sh); return sh;
}

# GPU layernorm backward (BIT-EXACT, plain --gpu). dx + dgamma/dbeta from saved mean/rstd. Returns
# 0 = ran, -1 = use CPU. Passes run 1→3→2 to fit the 7-BO pool. Local tile TK=8 (C,M %8).
fn gpu_ln_bwd(x, gamma, dy, mean, rstd, dx, dgamma, dbeta, M, C): i64 {
    if (_gpu_init() == 0) { return 0 - 1; }
    var TK = 8;
    if (C <= 0) { return 0 - 1; }
    if ((C % TK) != 0) { return 0 - 1; }            # P1 tiles C
    if ((M % TK) != 0) { return 0 - 1; }            # P2 tiles M
    if ((M * C) > MABDA_MAX_DISPATCH_DIM) { return 0 - 1; }
    var mc = M * C;
    if ((mc * 8) > GPU_BO_MAX()) { return 0 - 1; }
    var invC = f64_div(f64_from(1), f64_from(C));
    var i = 0;
    while (i < mc) { store64(_gpu_xm + i*8, load64(x + i*8)); i = i + 1; }       # x → x
    i = 0; while (i < mc) { store64(_gpu_wm + i*8, load64(dy + i*8)); i = i + 1; }   # dy → W
    i = 0; while (i < C) { store64(_gpu_gm + i*8, load64(gamma + i*8)); i = i + 1; } # gamma → gamma
    i = 0;
    while (i < M) { store64(_gpu_sm + i*8, load64(mean + i*8)); store64(_gpu_vm + i*8, load64(rstd + i*8)); i = i + 1; }
    # ---- P1 row-reduce → Mpack (y), zero-init ----
    i = 0; while (i < 2*M) { store64(_gpu_ym + i*8, f64_from(0)); i = i + 1; }
    var c0 = 0;
    while (c0 < C) {
        var sh = _gpu_get_lnbwd_red(C, c0, M, TK);
        if (sh == 0) { return 0 - 1; }
        var bp[128]; store64(&bp+0, 6);
        store64(&bp+8, _gpu_xh); store64(&bp+16, _GPU_XVA());
        store64(&bp+24, _gpu_wh); store64(&bp+32, _GPU_WVA());
        store64(&bp+40, _gpu_gh); store64(&bp+48, _GPU_GVA());
        store64(&bp+56, _gpu_sh); store64(&bp+64, _GPU_SVA());
        store64(&bp+72, _gpu_vh); store64(&bp+80, _GPU_VVA());
        store64(&bp+88, _gpu_yh); store64(&bp+96, _GPU_YVA());
        if (gpu_compute_dispatch(_gpu_ctx, sh, M, 1, 1, &bp) != 0) { return 0 - 1; }
        c0 = c0 + TK;
    }
    i = 0; while (i < 2*M) { store64(_gpu_ym + i*8, f64_mul(load64(_gpu_ym + i*8), invC)); i = i + 1; }
    # ---- P3 dx → beta ----
    var sh3 = _gpu_get_lnbwd_dx(C, M);
    if (sh3 == 0) { return 0 - 1; }
    var bp3[128]; store64(&bp3+0, 7);
    store64(&bp3+8, _gpu_xh); store64(&bp3+16, _GPU_XVA());
    store64(&bp3+24, _gpu_wh); store64(&bp3+32, _GPU_WVA());
    store64(&bp3+40, _gpu_gh); store64(&bp3+48, _GPU_GVA());
    store64(&bp3+56, _gpu_sh); store64(&bp3+64, _GPU_SVA());
    store64(&bp3+72, _gpu_vh); store64(&bp3+80, _GPU_VVA());
    store64(&bp3+88, _gpu_yh); store64(&bp3+96, _GPU_YVA());
    store64(&bp3+104, _gpu_bbh); store64(&bp3+112, _GPU_BVA());
    if (gpu_compute_dispatch(_gpu_ctx, sh3, mc, 1, 1, &bp3) != 0) { return 0 - 1; }
    i = 0; while (i < mc) { store64(dx + i*8, load64(_gpu_bbm + i*8)); i = i + 1; }
    # ---- P2 dgamma/dbeta (RMW onto seeds): dgamma → gamma, dbeta → y ----
    i = 0;
    while (i < C) {
        store64(_gpu_gm + i*8, load64(dgamma + i*8)); store64(_gpu_ym + i*8, load64(dbeta + i*8)); i = i + 1;
    }
    var m0 = 0;
    while (m0 < M) {
        var sh2 = _gpu_get_lnbwd_param(C, m0, M, TK);
        if (sh2 == 0) { return 0 - 1; }
        var bp2[128]; store64(&bp2+0, 6);
        store64(&bp2+8, _gpu_xh); store64(&bp2+16, _GPU_XVA());
        store64(&bp2+24, _gpu_wh); store64(&bp2+32, _GPU_WVA());
        store64(&bp2+40, _gpu_sh); store64(&bp2+48, _GPU_SVA());
        store64(&bp2+56, _gpu_vh); store64(&bp2+64, _GPU_VVA());
        store64(&bp2+72, _gpu_gh); store64(&bp2+80, _GPU_GVA());
        store64(&bp2+88, _gpu_yh); store64(&bp2+96, _GPU_YVA());
        if (gpu_compute_dispatch(_gpu_ctx, sh2, C, 1, 1, &bp2) != 0) { return 0 - 1; }
        m0 = m0 + TK;
    }
    i = 0;
    while (i < C) {
        store64(dgamma + i*8, load64(_gpu_gm + i*8)); store64(dbeta + i*8, load64(_gpu_ym + i*8)); i = i + 1;
    }
    _gpu_lnbwd_count = _gpu_lnbwd_count + 1;
    return 0;
}

# ===========================================================================
# 1.8.10 — attention backward on GPU (causal MHA), TOLERANCE → the full training step on-device.
# 6 dispatches / 5 kernels (E,F share the gather kernel). The forward zeroed Pc's upper triangle
# (Pc[h,i,j]=0 for j>i), so every reduction/gather loops the FULL range UNMASKED — j>i / i<j terms
# zero out. Untiled (loops T) → gate T ≤ 32 (default 16 engages; preset 64 → CPU). MHA only
# (nkv==nh → base=kvb=h·hd, Ckv=C); caller gates g_bidir. See docs/architecture/011-gpu-attention.md.
# ===========================================================================

# A dP[h,i,j] = Σ_d dconcat[i,base+d]·V[j,base+d]. dc=0(%12) V=1(%13) dP=2(%14). grid nh·T·T.
fn _gpu_build_abwd_dp(buf, T, C, hd): i64 {
    var o = _gpu_pre(buf, 3, 21);
    o=_gpu_op4(buf,o,0x0004002B,3,15,0); o=_gpu_op4(buf,o,0x0004002B,3,16,T);
    o=_gpu_op4(buf,o,0x0004002B,3,17,C); o=_gpu_op4(buf,o,0x0004002B,3,18,hd);
    o=_gpu_op4(buf,o,0x0004002B,3,19,T*T); o=_gpu_op4(buf,o,0x0004002B,3,20,1);
    o=_gpu_op5(buf,o,0x00050036,1,21,0,2); o=_gpu_op2(buf,o,0x000200F8,22);
    o=_gpu_op4(buf,o,0x0004003D,4,23,11); o=_gpu_op5(buf,o,0x00050051,3,24,23,0);
    o=_gpu_op5(buf,o,0x00050086,3,25,24,19);                       # h = idx/TT
    o=_gpu_op5(buf,o,0x00050084,3,26,25,19); o=_gpu_op5(buf,o,0x00050082,3,27,24,26);   # r
    o=_gpu_op5(buf,o,0x00050086,3,28,27,16);                       # i = r/T
    o=_gpu_op5(buf,o,0x00050084,3,29,28,16); o=_gpu_op5(buf,o,0x00050082,3,30,27,29);   # j
    o=_gpu_op5(buf,o,0x00050084,3,31,25,18);                       # hhd = base
    o=_gpu_op5(buf,o,0x00050084,3,32,28,17); o=_gpu_op5(buf,o,0x00050080,3,33,32,31);   # dcb = i*C+base
    o=_gpu_op5(buf,o,0x00050084,3,34,30,17); o=_gpu_op5(buf,o,0x00050080,3,35,34,31);   # vb = j*C+base
    var di=33; var vi=35; var nid=36; var acc=0; var d=0;
    while (d < hd) {
        var dp=nid; var dv=nid+1; o=_gpu_acl6(buf,o,dp,dv,12,15,di); nid=nid+2;
        var vp=nid; var vv=nid+1; o=_gpu_acl6(buf,o,vp,vv,13,15,vi); nid=nid+2;
        var pr=nid; nid=nid+1; o=_gpu_op5(buf,o,0x00050085,6,pr,dv,vv);
        if (d==0) { acc=pr; } else { var an=nid; nid=nid+1; o=_gpu_op5(buf,o,0x00050081,6,an,acc,pr); acc=an; }
        if (d<hd-1) {
            var dn=nid;
            nid=nid+1;
            o=_gpu_op5(buf,o,0x00050080,3,dn,di,20);
            di=dn;
            var vn=nid;
            nid=nid+1;
            o=_gpu_op5(buf,o,0x00050080,3,vn,vi,20);
            vi=vn;
        }
        d=d+1;
    }
    var pp=nid; nid=nid+1; o=_gpu_op6(buf,o,0x00060041,10,pp,14,15,24); o=_gpu_op3(buf,o,0x0003003E,pp,acc);
    o=_gpu_op2(buf,o,0x000100FD,0x00010038); store32(buf+12,nid); return o;
}

# B dotPdP[h,i] += Σ_{j∈[t0,t0+tk)} P[prow+j]·dP[prow+j]. P=0(%12) dP=1(%13) dotPdP=2(%14). grid nh·T.
# 1.9.0 TILED over j (RMW onto a pre-zeroed dotPdP), so T>20 fits the 256-id cap. consts %18=t0.
fn _gpu_build_abwd_dot_t(buf, T, t0, tk): i64 {
    var o = _gpu_pre(buf, 3, 19);
    o=_gpu_op4(buf,o,0x0004002B,3,15,0); o=_gpu_op4(buf,o,0x0004002B,3,16,T); o=_gpu_op4(buf,o,0x0004002B,3,17,1);
    o=_gpu_op4(buf,o,0x0004002B,3,18,t0);
    o=_gpu_op5(buf,o,0x00050036,1,19,0,2); o=_gpu_op2(buf,o,0x000200F8,20);
    o=_gpu_op4(buf,o,0x0004003D,4,21,11); o=_gpu_op5(buf,o,0x00050051,3,22,21,0);   # idx
    o=_gpu_op5(buf,o,0x00050084,3,23,22,16);                       # prow = idx*T
    o=_gpu_op5(buf,o,0x00050080,3,24,23,18);                       # pj0 = prow + t0
    o=_gpu_op6(buf,o,0x00060041,10,25,14,15,22); o=_gpu_op4(buf,o,0x0004003D,6,26,25);  # acc = dotPdP[idx] (RMW)
    var pj=24; var acc=26; var nid=27; var j=0;
    while (j < tk) {
        var pp=nid; var pv=nid+1; o=_gpu_acl6(buf,o,pp,pv,12,15,pj); nid=nid+2;
        var qp=nid; var qv=nid+1; o=_gpu_acl6(buf,o,qp,qv,13,15,pj); nid=nid+2;
        var pr=nid; nid=nid+1; o=_gpu_op5(buf,o,0x00050085,6,pr,pv,qv);
        var an=nid; nid=nid+1; o=_gpu_op5(buf,o,0x00050081,6,an,acc,pr); acc=an;
        if (j<tk-1) { var pn=nid; nid=nid+1; o=_gpu_op5(buf,o,0x00050080,3,pn,pj,17); pj=pn; }
        j=j+1;
    }
    o=_gpu_op3(buf,o,0x0003003E,25,acc);
    o=_gpu_op2(buf,o,0x000100FD,0x00010038); store32(buf+12,nid); return o;
}

# C sds[h,i,j] = scale·P[idx]·(dP[idx] − dotPdP[t2]). P=0(%12) dPsds=1(%13,io) dotPdP=2(%14). grid nh·T·T.
fn _gpu_build_abwd_sds(buf, T, scale): i64 {
    var o = _gpu_pre(buf, 3, 19);
    o=_gpu_op4(buf,o,0x0004002B,3,15,0); o=_gpu_op4(buf,o,0x0004002B,3,16,T); o=_gpu_ecf6(buf,o,17,scale);
    o=_gpu_op5(buf,o,0x00050036,1,19,0,2); o=_gpu_op2(buf,o,0x000200F8,20);
    o=_gpu_op4(buf,o,0x0004003D,4,21,11); o=_gpu_op5(buf,o,0x00050051,3,22,21,0);   # idx
    o=_gpu_op5(buf,o,0x00050086,3,23,22,16);                       # t2 = idx/T
    o=_gpu_op6(buf,o,0x00060041,10,24,12,15,22); o=_gpu_op4(buf,o,0x0004003D,6,25,24);  # p = P[idx]
    o=_gpu_op6(buf,o,0x00060041,10,26,13,15,22); o=_gpu_op4(buf,o,0x0004003D,6,27,26);  # dp = dPsds[idx]
    o=_gpu_op6(buf,o,0x00060041,10,28,14,15,23); o=_gpu_op4(buf,o,0x0004003D,6,29,28);  # dd = dotPdP[t2]
    o=_gpu_op5(buf,o,0x00050083,6,30,27,29);                       # dp - dd
    o=_gpu_op5(buf,o,0x00050085,6,31,25,30);                       # p*(...)
    o=_gpu_op5(buf,o,0x00050085,6,32,17,31);                       # scale*...
    o=_gpu_op3(buf,o,0x0003003E,26,32);                            # dPsds[idx] = sds
    o=_gpu_op2(buf,o,0x000100FD,0x00010038); store32(buf+12,33); return o;
}

# D dQ[i,base+d] += Σ_{j∈[t0,t0+tk)} sds[prow+j]·K[j*C+base+d]. sds=0(%12) K=1(%13) dQ=2(%14). grid nh·T·hd.
# 1.9.0 TILED over j (RMW onto a pre-zeroed dQ). consts %20=t0; sj0=prow+t0, ki0=kb0+t0*C.
fn _gpu_build_abwd_dq_t(buf, T, C, hd, t0, tk): i64 {
    var o = _gpu_pre(buf, 3, 21);
    o=_gpu_op4(buf,o,0x0004002B,3,15,0); o=_gpu_op4(buf,o,0x0004002B,3,16,T);
    o=_gpu_op4(buf,o,0x0004002B,3,17,C); o=_gpu_op4(buf,o,0x0004002B,3,18,hd); o=_gpu_op4(buf,o,0x0004002B,3,19,1);
    o=_gpu_op4(buf,o,0x0004002B,3,20,t0);
    o=_gpu_op5(buf,o,0x00050036,1,21,0,2); o=_gpu_op2(buf,o,0x000200F8,22);
    o=_gpu_op4(buf,o,0x0004003D,4,23,11); o=_gpu_op5(buf,o,0x00050051,3,24,23,0);   # idx
    o=_gpu_op5(buf,o,0x00050086,3,25,24,18);                       # q = idx/hd
    o=_gpu_op5(buf,o,0x00050084,3,26,25,18);
    o=_gpu_op5(buf,o,0x00050082,3,27,24,26);                       # d = idx - q*hd
    o=_gpu_op5(buf,o,0x00050086,3,28,25,16);                       # t2 = q/T
    o=_gpu_op5(buf,o,0x00050084,3,29,28,16);
    o=_gpu_op5(buf,o,0x00050082,3,30,25,29);                       # i = q - t2*T
    o=_gpu_op5(buf,o,0x00050084,3,31,28,18);                       # base = t2*hd
    o=_gpu_op5(buf,o,0x00050084,3,32,25,16);                       # prow = q*T
    o=_gpu_op5(buf,o,0x00050084,3,33,30,17);                       # i*C
    o=_gpu_op5(buf,o,0x00050080,3,34,33,31);                       # i*C+base
    o=_gpu_op5(buf,o,0x00050080,3,35,34,27);                       # dqo = i*C+base+d
    o=_gpu_op5(buf,o,0x00050080,3,36,31,27);                       # kb0 = base+d
    o=_gpu_op5(buf,o,0x00050080,3,37,32,20);                       # sj0 = prow + t0
    o=_gpu_op5(buf,o,0x00050084,3,38,20,17);                       # t0*C
    o=_gpu_op5(buf,o,0x00050080,3,39,36,38);                       # ki0 = kb0 + t0*C
    o=_gpu_op6(buf,o,0x00060041,10,40,14,15,35); o=_gpu_op4(buf,o,0x0004003D,6,41,40);  # acc = dQ[dqo] (RMW)
    var sj=37; var ki=39; var acc=41; var nid=42; var j=0;
    while (j < tk) {
        var sp=nid; var sv=nid+1; o=_gpu_acl6(buf,o,sp,sv,12,15,sj); nid=nid+2;
        var kp=nid; var kv=nid+1; o=_gpu_acl6(buf,o,kp,kv,13,15,ki); nid=nid+2;
        var pr=nid; nid=nid+1; o=_gpu_op5(buf,o,0x00050085,6,pr,sv,kv);
        var an=nid; nid=nid+1; o=_gpu_op5(buf,o,0x00050081,6,an,acc,pr); acc=an;
        if (j<tk-1) {
            var sn=nid;
            nid=nid+1;
            o=_gpu_op5(buf,o,0x00050080,3,sn,sj,19);
            sj=sn;
            var kn=nid;
            nid=nid+1;
            o=_gpu_op5(buf,o,0x00050080,3,kn,ki,17);
            ki=kn;
        }
        j=j+1;
    }
    o=_gpu_op3(buf,o,0x0003003E,40,acc);
    o=_gpu_op2(buf,o,0x000100FD,0x00010038); store32(buf+12,nid); return o;
}

# G gather: out[j,base+d] += Σ_{i∈[t0,t0+tk)} A[h*TT + i*T + j]·B[i*C + base+d]. A=0(%12) B=1(%13)
# out=2(%14). grid nh·T·hd. Used for dV (A=P,B=dconcat) and dK (A=sds,B=Q). 1.9.0 TILED over i (RMW
# onto a pre-zeroed out). consts %20=t0; ai0=Ab0+t0*T, bi0=Bb0+t0*C.
fn _gpu_build_abwd_gather_t(buf, T, C, hd, t0, tk): i64 {
    var o = _gpu_pre(buf, 3, 21);
    o=_gpu_op4(buf,o,0x0004002B,3,15,0); o=_gpu_op4(buf,o,0x0004002B,3,16,T);
    o=_gpu_op4(buf,o,0x0004002B,3,17,C); o=_gpu_op4(buf,o,0x0004002B,3,18,hd); o=_gpu_op4(buf,o,0x0004002B,3,19,T*T);
    o=_gpu_op4(buf,o,0x0004002B,3,20,t0);
    o=_gpu_op5(buf,o,0x00050036,1,21,0,2); o=_gpu_op2(buf,o,0x000200F8,22);
    o=_gpu_op4(buf,o,0x0004003D,4,23,11); o=_gpu_op5(buf,o,0x00050051,3,24,23,0);   # idx
    o=_gpu_op5(buf,o,0x00050086,3,25,24,18);                       # q = idx/hd
    o=_gpu_op5(buf,o,0x00050084,3,26,25,18);
    o=_gpu_op5(buf,o,0x00050082,3,27,24,26);                       # d
    o=_gpu_op5(buf,o,0x00050086,3,28,25,16);                       # h = q/T
    o=_gpu_op5(buf,o,0x00050084,3,29,28,16);
    o=_gpu_op5(buf,o,0x00050082,3,30,25,29);                       # j
    o=_gpu_op5(buf,o,0x00050084,3,31,28,18);                       # base = h*hd
    o=_gpu_op5(buf,o,0x00050084,3,32,28,19); o=_gpu_op5(buf,o,0x00050080,3,33,32,30);  # Ab0 = h*TT + j
    o=_gpu_op5(buf,o,0x00050084,3,34,30,17);
    o=_gpu_op5(buf,o,0x00050080,3,35,34,31);
    o=_gpu_op5(buf,o,0x00050080,3,36,35,27);                       # outo = j*C+base+d
    o=_gpu_op5(buf,o,0x00050080,3,37,31,27);                       # Bb0 = base+d
    o=_gpu_op5(buf,o,0x00050084,3,38,20,16);                       # t0*T
    o=_gpu_op5(buf,o,0x00050080,3,39,33,38);                       # ai0 = Ab0 + t0*T
    o=_gpu_op5(buf,o,0x00050084,3,40,20,17);                       # t0*C
    o=_gpu_op5(buf,o,0x00050080,3,41,37,40);                       # bi0 = Bb0 + t0*C
    o=_gpu_op6(buf,o,0x00060041,10,42,14,15,36); o=_gpu_op4(buf,o,0x0004003D,6,43,42);  # acc = out[outo] (RMW)
    var ai=39; var bi=41; var acc=43; var nid=44; var i=0;
    while (i < tk) {
        var ap=nid; var av=nid+1; o=_gpu_acl6(buf,o,ap,av,12,15,ai); nid=nid+2;
        var bp=nid; var bv=nid+1; o=_gpu_acl6(buf,o,bp,bv,13,15,bi); nid=nid+2;
        var pr=nid; nid=nid+1; o=_gpu_op5(buf,o,0x00050085,6,pr,av,bv);
        var an=nid; nid=nid+1; o=_gpu_op5(buf,o,0x00050081,6,an,acc,pr); acc=an;
        if (i<tk-1) {
            var aN=nid;
            nid=nid+1;
            o=_gpu_op5(buf,o,0x00050080,3,aN,ai,16);
            ai=aN;
            var bN=nid;
            nid=nid+1;
            o=_gpu_op5(buf,o,0x00050080,3,bN,bi,17);
            bi=bN;
        }
        i=i+1;
    }
    o=_gpu_op3(buf,o,0x0003003E,42,acc);
    o=_gpu_op2(buf,o,0x000100FD,0x00010038); store32(buf+12,nid); return o;
}

# Non-tiled abwd kernels (dp loops hd, sds is elementwise — neither loops T, so both fit the cap).
# hd is in the key: the dp kernel (kind 16) BAKES hd (dot length + per-head base) into its SPIR-V, so
# two shapes sharing (C,T) but differing in nh (→ hd=C/nh) must not collide on a stale cached shader.
fn _gpu_get_abwd(kind, T, C, hd, scale): i64 {
    var key = (kind << 56) | (hd << 28) | (C << 14) | T;
    var c = _gpu_cache_get(key); if (c == (0 - 1)) { return 0; } if (c != 0) { return c; }
    var spv[8192]; var nb = 0;
    if (kind == 16) { nb = _gpu_build_abwd_dp(&spv, T, C, hd); }
    else { nb = _gpu_build_abwd_sds(&spv, T, scale); }
    var sh = gpu_shader_module_create_spirv(_gpu_ctx, &spv, nb);
    if (sh == 0) { _gpu_cache_put(key, 0 - 1); return 0; }
    _gpu_cache_put(key, sh); return sh;
}

# Tiled abwd kernels (dot/dq/gather loop T → tiled over [t0,t0+tk), RMW). Keyed incl. t0,tk so each
# tile's distinct kernel caches independently. kind 17=dot, 19=dq, 20=gather.
fn _gpu_get_abwd_t(kind, T, C, hd, t0, tk): i64 {
    var key = (kind << 56) | (C << 34) | (hd << 27) | (T << 16) | (t0 << 5) | tk;
    var c = _gpu_cache_get(key); if (c == (0 - 1)) { return 0; } if (c != 0) { return c; }
    var spv[8192]; var nb = 0;
    if (kind == 17) { nb = _gpu_build_abwd_dot_t(&spv, T, t0, tk); }
    elif (kind == 19) { nb = _gpu_build_abwd_dq_t(&spv, T, C, hd, t0, tk); }
    else { nb = _gpu_build_abwd_gather_t(&spv, T, C, hd, t0, tk); }
    var sh = gpu_shader_module_create_spirv(_gpu_ctx, &spv, nb);
    if (sh == 0) { _gpu_cache_put(key, 0 - 1); return 0; }
    _gpu_cache_put(key, sh); return sh;
}

# one 3-binding dispatch (count, (h,va)×3)
fn _gpu_abwd_disp(sh, h0,v0, h1,v1, h2,v2, grid): i64 {
    var bp[56]; store64(&bp+0, 3);
    store64(&bp+8,h0); store64(&bp+16,v0); store64(&bp+24,h1); store64(&bp+32,v1);
    store64(&bp+40,h2); store64(&bp+48,v2);
    return gpu_compute_dispatch(_gpu_ctx, sh, grid, 1, 1, &bp);
}

# GPU attention backward (causal MHA, TOLERANCE). dQ/dK/dV from Qc/Kc/Vc/Pc/dconcat. Returns 0 = ran,
# -1 = CPU. dprow unused (GPU keeps dP in the y-buf). Buffers: x=dconcat→P, y=dP/sds, W cycles
# (V/K/dconcat/Q), gamma=dQ/dV/dK out, beta=dotPdP. 1.9.0: the T-reductions (B dotPdP, D dQ, E dV,
# F dK) are TILED over T in TK chunks (RMW onto a pre-zeroed output, serialized dispatches → no race),
# so any T fits the 256-id cap — preset T=64 now runs on-device (the cap/BO checks alone gate fallback).
fn gpu_attn_core_bwd(Qc, Kc, Vc, Pc, dconcat, dQ, dK, dV, dprow, T, C, nh, nkv): i64 {
    if (_gpu_init() == 0) { return 0 - 1; }
    if (nkv != nh) { return 0 - 1; }            # GQA → CPU
    if (T <= 0) { return 0 - 1; }
    var hd = C / nh; var Ckv = C;
    if (hd <= 0) { return 0 - 1; }
    if (hd > 32) { return 0 - 1; }              # pass A (dp) is UNTILED — unrolls hd into spv[8192];
    # hd>32 would overflow the build buffer → CPU (never a crash)
    var TK = 16;
    var PN = nh * T * T;
    if ((PN * 8) > GPU_BO_MAX()) { return 0 - 1; }
    if (PN > MABDA_MAX_DISPATCH_DIM) { return 0 - 1; }
    if ((nh * T * hd) > MABDA_MAX_DISPATCH_DIM) { return 0 - 1; }
    if ((T * C * 8) > GPU_BO_MAX()) { return 0 - 1; }
    var scale = f64_div(f64_from(1), f64_sqrt(f64_from(hd)));
    var tc = T * C;
    var i = 0;
    # ---- A: dP = Σ_d dconcat·V → y (untiled, loops hd). (dconcat→x, V→W) ----
    while (i < tc) { store64(_gpu_xm + i*8, load64(dconcat + i*8)); i = i + 1; }
    i = 0; while (i < tc) { store64(_gpu_wm + i*8, load64(Vc + i*8)); i = i + 1; }
    var sa = _gpu_get_abwd(16, T, C, hd, scale);
    if (sa == 0) { return 0 - 1; }
    if (_gpu_abwd_disp(sa, _gpu_xh,_GPU_XVA(), _gpu_wh,_GPU_WVA(), _gpu_yh,_GPU_YVA(), PN) != 0) { return 0 - 1; }
    # ---- B: dotPdP = Σ_j P·dP → beta (TILED over j, RMW). (P→x, dP in y) ----
    i = 0; while (i < PN) { store64(_gpu_xm + i*8, load64(Pc + i*8)); i = i + 1; }
    i = 0; while (i < nh*T) { store64(_gpu_bbm + i*8, f64_from(0)); i = i + 1; }
    var t0 = 0;
    while (t0 < T) {
        var tkb = TK; if (T - t0 < TK) { tkb = T - t0; }
        var sb = _gpu_get_abwd_t(17, T, C, hd, t0, tkb);
        if (sb == 0) { return 0 - 1; }
        var rb = _gpu_abwd_disp(sb, _gpu_xh,_GPU_XVA(), _gpu_yh,_GPU_YVA(), _gpu_bbh,_GPU_BVA(), nh*T);
        if (rb != 0) { return 0 - 1; }
        t0 = t0 + tkb;
    }
    # ---- C: sds = scale·P·(dP − dotPdP) → y (in-place, elementwise). (P in x, dPsds in y, dotPdP in beta) ----
    var sc = _gpu_get_abwd(18, T, C, hd, scale);
    if (sc == 0) { return 0 - 1; }
    if (_gpu_abwd_disp(sc, _gpu_xh,_GPU_XVA(), _gpu_yh,_GPU_YVA(), _gpu_bbh,_GPU_BVA(), PN) != 0) { return 0 - 1; }
    # ---- D: dQ = Σ_j sds·K → gamma (TILED over j, RMW). (sds in y, K→W) ----
    i = 0; while (i < tc) { store64(_gpu_wm + i*8, load64(Kc + i*8)); i = i + 1; }
    i = 0; while (i < tc) { store64(_gpu_gm + i*8, f64_from(0)); i = i + 1; }
    t0 = 0;
    while (t0 < T) {
        var tkd = TK; if (T - t0 < TK) { tkd = T - t0; }
        var sd = _gpu_get_abwd_t(19, T, C, hd, t0, tkd);
        if (sd == 0) { return 0 - 1; }
        var rd = _gpu_abwd_disp(sd, _gpu_yh,_GPU_YVA(), _gpu_wh,_GPU_WVA(), _gpu_gh,_GPU_GVA(), nh*T*hd);
        if (rd != 0) { return 0 - 1; }
        t0 = t0 + tkd;
    }
    i = 0; while (i < tc) { store64(dQ + i*8, load64(_gpu_gm + i*8)); i = i + 1; }
    # ---- E: dV = Σ_i P·dconcat → gamma (TILED over i, RMW). (P in x, dconcat→W) ----
    i = 0; while (i < tc) { store64(_gpu_wm + i*8, load64(dconcat + i*8)); i = i + 1; }
    i = 0; while (i < tc) { store64(_gpu_gm + i*8, f64_from(0)); i = i + 1; }
    t0 = 0;
    while (t0 < T) {
        var tke = TK; if (T - t0 < TK) { tke = T - t0; }
        var se = _gpu_get_abwd_t(20, T, C, hd, t0, tke);
        if (se == 0) { return 0 - 1; }
        var re = _gpu_abwd_disp(se, _gpu_xh,_GPU_XVA(), _gpu_wh,_GPU_WVA(), _gpu_gh,_GPU_GVA(), nh*T*hd);
        if (re != 0) { return 0 - 1; }
        t0 = t0 + tke;
    }
    i = 0; while (i < tc) { store64(dV + i*8, load64(_gpu_gm + i*8)); i = i + 1; }
    # ---- F: dK = Σ_i sds·Q → gamma (TILED over i, RMW; reuses the gather kernel A=sds,B=Q). (sds in y, Q→W) ----
    i = 0; while (i < tc) { store64(_gpu_wm + i*8, load64(Qc + i*8)); i = i + 1; }
    i = 0; while (i < tc) { store64(_gpu_gm + i*8, f64_from(0)); i = i + 1; }
    t0 = 0;
    while (t0 < T) {
        var tkf = TK; if (T - t0 < TK) { tkf = T - t0; }
        var sf = _gpu_get_abwd_t(20, T, C, hd, t0, tkf);
        if (sf == 0) { return 0 - 1; }
        var rf = _gpu_abwd_disp(sf, _gpu_yh,_GPU_YVA(), _gpu_wh,_GPU_WVA(), _gpu_gh,_GPU_GVA(), nh*T*hd);
        if (rf != 0) { return 0 - 1; }
        t0 = t0 + tkf;
    }
    i = 0; while (i < tc) { store64(dK + i*8, load64(_gpu_gm + i*8)); i = i + 1; }
    _gpu_attnbwd_count = _gpu_attnbwd_count + 1;
    return 0;
}

# ===========================================================================
# 1.8.4 — the FULL fused attention core (causal MHA), TOLERANCE-validated. The hardest GPU
# op: 4 passes (scores → rowmax → exp+sum → PV) over the Qc/Kc/Vc the QKV matmuls produced.
# Causality: scores store -1e8 for j>i (a finite sentinel that underflows exp→0 without the
# i32 range-reduction overflow a true -inf would cause, and sits far below any real score),
# so passes 2-4 are mask-FREE. Reductions are j-tiled to keep the synth-id budget under the
# 256-id cap. Rides g_gpu_tc (in-shader exp → tolerance). See docs/architecture/011-gpu-attention.md.
# ===========================================================================

# Attn preamble: GLSL %1, void %2, fn %3, uint %4, uvec3 %5, ptrIn %6, double %7, rtarr %8,
# struct %9, ptrSB-struct %10, ptrSB-double %11, int %12, bool %13, gid %14, buffers %15..
fn _gpu_pre_a(buf, nbind, fnid): i64 {
    var o = _gpu_op3(buf, 0, 0x07230203, 0x00010300, 0x00000000);
    o = _gpu_op2(buf, o, 0x00000000, 0x00000000);
    o = _gpu_op2(buf, o, 0x00020011, 1); o = _gpu_op2(buf, o, 0x00020011, 10);
    o = _gpu_op3(buf, o, 0x0006000B, 1, 0x4C534C47);     # OpExtInstImport "GLSL.std.450"
    store32(buf+o,0x6474732E); store32(buf+o+4,0x3035342E); store32(buf+o+8,0x00000000); o=o+12;
    o = _gpu_op3(buf, o, 0x0003000E, 0, 1);
    o = _gpu_op6(buf, o, 0x0006000F, 5, fnid, 0x6E69616D, 0x00000000, 14);
    o = _gpu_op6(buf, o, 0x00060010, fnid, 17, 1, 1, 1);
    o = _gpu_op4(buf, o, 0x00040047, 14, 11, 28);
    var i = 0;
    while (i < nbind) {
        o = _gpu_op4(buf, o, 0x00040047, 15+i, 33, i); o = _gpu_op4(buf, o, 0x00040047, 15+i, 34, 0); i = i+1;
    }
    o = _gpu_op2(buf, o, 0x00020013, 2); o = _gpu_op3(buf, o, 0x00030021, 3, 2);
    o = _gpu_op4(buf, o, 0x00040015, 4, 32, 0); o = _gpu_op4(buf, o, 0x00040017, 5, 4, 3);
    o = _gpu_op4(buf, o, 0x00040020, 6, 1, 5); o = _gpu_op3(buf, o, 0x00030016, 7, 64);
    o = _gpu_op3(buf, o, 0x0003001D, 8, 7); o = _gpu_op3(buf, o, 0x0003001E, 9, 8);
    o = _gpu_op4(buf, o, 0x00040020, 10, 12, 9); o = _gpu_op4(buf, o, 0x00040020, 11, 12, 7);
    o = _gpu_op4(buf, o, 0x00040015, 12, 32, 1); o = _gpu_op2(buf, o, 0x00020014, 13);
    o = _gpu_op4(buf, o, 0x0004003B, 6, 14, 1);
    i = 0; while (i < nbind) { o = _gpu_op4(buf, o, 0x0004003B, 10, 15+i, 12); i = i+1; }
    return o;
}

# P1 scores: Q=0 K=1 P=2. P[h,i,j] = (j<=i) ? scale·Σ_d q·k : -1e8. grid nh*T*T.
fn _gpu_attn_scores(buf, T, C, hd, Ckv, scale): i64 {
    var o = _gpu_pre_a(buf, 3, 30);
    o = _gpu_op4(buf, o, 0x0004002B, 4, 18, 0); o = _gpu_op4(buf, o, 0x0004002B, 4, 19, T);
    o = _gpu_op4(buf, o, 0x0004002B, 4, 20, C); o = _gpu_op4(buf, o, 0x0004002B, 4, 21, hd);
    o = _gpu_op4(buf, o, 0x0004002B, 4, 22, Ckv); o = _gpu_op4(buf, o, 0x0004002B, 4, 23, T*T);
    o = _gpu_ecf(buf, o, 24, scale); o = _gpu_ecf(buf, o, 25, 0xC197D78400000000);    # -1e8 (causal sentinel)
    o = _gpu_op4(buf, o, 0x0004002B, 4, 26, 1);
    o = _gpu_op5(buf, o, 0x00050036, 2, 30, 0, 3); o = _gpu_op2(buf, o, 0x000200F8, 31);
    o = _gpu_op4(buf, o, 0x0004003D, 5, 32, 14);
    o = _gpu_op5(buf, o, 0x00050051, 4, 33, 32, 0);
    o = _gpu_op5(buf, o, 0x00050086, 4, 34, 33, 23); o = _gpu_op5(buf, o, 0x00050089, 4, 35, 33, 23);
    o = _gpu_op5(buf, o, 0x00050086, 4, 36, 35, 19); o = _gpu_op5(buf, o, 0x00050089, 4, 37, 35, 19);
    o = _gpu_op5(buf, o, 0x00050084, 4, 38, 34, 21);
    o = _gpu_op5(buf, o, 0x00050084, 4, 39, 36, 20); o = _gpu_op5(buf, o, 0x00050080, 4, 40, 39, 38);
    o = _gpu_op5(buf, o, 0x00050084, 4, 41, 37, 22); o = _gpu_op5(buf, o, 0x00050080, 4, 42, 41, 38);
    var qi = 40; var ki = 42; var nid = 43; var acc = 0; var d = 0;
    while (d < hd) {
        var qp = nid; nid=nid+1; o = _gpu_op6(buf, o, 0x00060041, 11, qp, 15, 18, qi);
        var qv = nid; nid=nid+1; o = _gpu_op4(buf, o, 0x0004003D, 7, qv, qp);
        var kp = nid; nid=nid+1; o = _gpu_op6(buf, o, 0x00060041, 11, kp, 16, 18, ki);
        var kvv = nid; nid=nid+1; o = _gpu_op4(buf, o, 0x0004003D, 7, kvv, kp);
        var pr = nid; nid=nid+1; o = _gpu_op5(buf, o, 0x00050085, 7, pr, qv, kvv);
        if (d == 0) { acc = pr; }
        else { var an=nid; nid=nid+1; o = _gpu_op5(buf, o, 0x00050081, 7, an, acc, pr); acc=an; }
        if (d < hd-1) {
            var qn=nid; nid=nid+1; o = _gpu_op5(buf, o, 0x00050080, 4, qn, qi, 26); qi=qn;
            var kn=nid; nid=nid+1; o = _gpu_op5(buf, o, 0x00050080, 4, kn, ki, 26); ki=kn;
        }
        d = d + 1;
    }
    var scl=nid; nid=nid+1; o = _gpu_op5(buf, o, 0x00050085, 7, scl, acc, 24);
    var ic=nid; nid=nid+1; o = _gpu_op4(buf, o, 0x0004006F, 7, ic, 36);
    var jc=nid; nid=nid+1; o = _gpu_op4(buf, o, 0x0004006F, 7, jc, 37);
    var cond=nid; nid=nid+1; o = _gpu_op5(buf, o, 0x000500BE, 13, cond, ic, jc);
    var sc=nid; nid=nid+1; o = _gpu_op6(buf, o, 0x000600A9, 7, sc, cond, scl, 25);
    var pp=nid; nid=nid+1; o = _gpu_op6(buf, o, 0x00060041, 11, pp, 17, 18, 33);
    o = _gpu_op3(buf, o, 0x0003003E, pp, sc);
    o = _gpu_op2(buf, o, 0x000100FD, 0x00010038); store32(buf+12, nid); return o;
}

# P2 rowmax (tiled): P=0 M=1. M[idx] = max(M[idx], max_{jj<TK} P[idx*T + k0+jj]). grid nh*T.
fn _gpu_attn_rowmax(buf, T, k0, TK): i64 {
    var o = _gpu_pre_a(buf, 2, 30);
    o = _gpu_op4(buf, o, 0x0004002B, 4, 18, 0); o = _gpu_op4(buf, o, 0x0004002B, 4, 19, T);
    o = _gpu_op4(buf, o, 0x0004002B, 4, 20, 1); o = _gpu_op4(buf, o, 0x0004002B, 4, 21, k0);
    o = _gpu_op5(buf, o, 0x00050036, 2, 30, 0, 3); o = _gpu_op2(buf, o, 0x000200F8, 31);
    o = _gpu_op4(buf, o, 0x0004003D, 5, 32, 14);
    o = _gpu_op5(buf, o, 0x00050051, 4, 33, 32, 0);
    o = _gpu_op5(buf, o, 0x00050084, 4, 34, 33, 19);     # prow = idx*T
    o = _gpu_op5(buf, o, 0x00050080, 4, 35, 34, 21);     # pbase = prow + k0
    o = _gpu_op6(buf, o, 0x00060041, 11, 36, 16, 18, 33);# &M[idx]
    o = _gpu_op4(buf, o, 0x0004003D, 7, 37, 36);         # m = M[idx]
    var pj=35; var m=37; var nid=38; var jj=0;
    while (jj < TK) {
        var pp=nid; nid=nid+1; o = _gpu_op6(buf, o, 0x00060041, 11, pp, 15, 18, pj);
        var pv=nid; nid=nid+1; o = _gpu_op4(buf, o, 0x0004003D, 7, pv, pp);
        var mn=nid; nid=nid+1; o = _gpu_op7(buf, o, 0x0007000C, 7, mn, 1, 40, m, pv); m=mn;
        if (jj < TK-1) { var pn=nid; nid=nid+1; o = _gpu_op5(buf, o, 0x00050080, 4, pn, pj, 20); pj=pn; }
        jj = jj + 1;
    }
    o = _gpu_op3(buf, o, 0x0003003E, 36, m);
    o = _gpu_op2(buf, o, 0x000100FD, 0x00010038); store32(buf+12, nid); return o;
}

# P3 exp+sum (tiled): P=0 M=1 L=2. for jj<TK: e=exp(P[prow+k0+jj]-M); P=e; L+=e. grid nh*T.
fn _gpu_attn_expsum(buf, T, k0, TK): i64 {
    var o = _gpu_pre_a(buf, 3, 40);
    o = _gpu_op4(buf, o, 0x0004002B, 4, 18, 0); o = _gpu_op4(buf, o, 0x0004002B, 4, 19, T);
    o = _gpu_op4(buf, o, 0x0004002B, 4, 20, 1); o = _gpu_op4(buf, o, 0x0004002B, 4, 21, k0);
    o = _gpu_ecf(buf, o, 22, 0x3FF71547652B82FE); o = _gpu_ecf(buf, o, 23, 0x3FE62E42FEFA39EF);
    o = _gpu_ecf(buf, o, 24, 0x4338000000000000); o = _gpu_ecf(buf, o, 25, 0x3E927E4FB7789F5C);
    o = _gpu_ecf(buf, o, 26, 0x3EC71DE3A556C734); o = _gpu_ecf(buf, o, 27, 0x3EFA01A01A01A01A);
    o = _gpu_ecf(buf, o, 28, 0x3F2A01A01A01A01A); o = _gpu_ecf(buf, o, 29, 0x3F56C16C16C16C17);
    o = _gpu_ecf(buf, o, 30, 0x3F81111111111111); o = _gpu_ecf(buf, o, 31, 0x3FA5555555555555);
    o = _gpu_ecf(buf, o, 32, 0x3FC5555555555555); o = _gpu_ecf(buf, o, 33, 0x3FE0000000000000);
    o = _gpu_ecf(buf, o, 34, 0x3FF0000000000000); o = _gpu_ecf(buf, o, 35, 0x3FF0000000000000);
    o = _gpu_op5(buf, o, 0x00050036, 2, 40, 0, 3); o = _gpu_op2(buf, o, 0x000200F8, 41);
    o = _gpu_op4(buf, o, 0x0004003D, 5, 42, 14);
    o = _gpu_op5(buf, o, 0x00050051, 4, 43, 42, 0);
    o = _gpu_op5(buf, o, 0x00050084, 4, 44, 43, 19);     # prow
    o = _gpu_op5(buf, o, 0x00050080, 4, 45, 44, 21);     # pbase = prow + k0
    o = _gpu_op6(buf, o, 0x00060041, 11, 46, 16, 18, 43); o = _gpu_op4(buf, o, 0x0004003D, 7, 47, 46);  # m
    o = _gpu_op6(buf, o, 0x00060041, 11, 48, 17, 18, 43); o = _gpu_op4(buf, o, 0x0004003D, 7, 49, 48);  # acc=L
    var pj=45; var acc=49; var nid=50; var jj=0;
    while (jj < TK) {
        var pp=nid; nid=nid+1; o = _gpu_op6(buf, o, 0x00060041, 11, pp, 15, 18, pj);
        var pv=nid; nid=nid+1; o = _gpu_op4(buf, o, 0x0004003D, 7, pv, pp);
        var x=nid; nid=nid+1; o = _gpu_op5(buf, o, 0x00050083, 7, x, pv, 47);
        var y=nid; nid=nid+1; o = _gpu_op5(buf, o, 0x00050085, 7, y, x, 22);
        var t1=nid; nid=nid+1; o = _gpu_op5(buf, o, 0x00050081, 7, t1, y, 24);
        var nf=nid; nid=nid+1; o = _gpu_op5(buf, o, 0x00050083, 7, nf, t1, 24);
        var m1=nid; nid=nid+1; o = _gpu_op5(buf, o, 0x00050085, 7, m1, nf, 23);
        var r=nid; nid=nid+1; o = _gpu_op5(buf, o, 0x00050083, 7, r, x, m1);
        var p=25; var ci=26;
        while (ci <= 35) {
            var mu=nid; nid=nid+1; o = _gpu_op5(buf, o, 0x00050085, 7, mu, r, p);
            var ad=nid; nid=nid+1; o = _gpu_op5(buf, o, 0x00050081, 7, ad, ci, mu); p=ad; ci=ci+1;
        }
        var ni=nid; nid=nid+1; o = _gpu_op4(buf, o, 0x0004006E, 12, ni, nf);
        var e=nid; nid=nid+1; o = _gpu_op7(buf, o, 0x0007000C, 7, e, 1, 53, p, ni);
        o = _gpu_op3(buf, o, 0x0003003E, pp, e);
        var an=nid; nid=nid+1; o = _gpu_op5(buf, o, 0x00050081, 7, an, acc, e); acc=an;
        if (jj < TK-1) { var pn=nid; nid=nid+1; o = _gpu_op5(buf, o, 0x00050080, 4, pn, pj, 20); pj=pn; }
        jj = jj + 1;
    }
    o = _gpu_op3(buf, o, 0x0003003E, 48, acc);
    o = _gpu_op2(buf, o, 0x000100FD, 0x00010038); store32(buf+12, nid); return o;
}

# P4 pv (tiled RMW): P=0 V=1 O=2. O[i,h,d] += Σ_{jj<TK} P[prow+k0+jj]·V[(k0+jj)*Ckv+h*hd+d].
# grid nh*T*hd. Host pre-zeros O + normalizes (O *= 1/sum) after. consts %18=0 %19=T %20=C
# %21=hd %22=Ckv %23=1 %24=k0 %25=k0*Ckv.
fn _gpu_attn_pv(buf, T, C, hd, Ckv, k0, TK): i64 {
    var o = _gpu_pre_a(buf, 3, 30);
    o = _gpu_op4(buf, o, 0x0004002B, 4, 18, 0); o = _gpu_op4(buf, o, 0x0004002B, 4, 19, T);
    o = _gpu_op4(buf, o, 0x0004002B, 4, 20, C); o = _gpu_op4(buf, o, 0x0004002B, 4, 21, hd);
    o = _gpu_op4(buf, o, 0x0004002B, 4, 22, Ckv); o = _gpu_op4(buf, o, 0x0004002B, 4, 23, 1);
    o = _gpu_op4(buf, o, 0x0004002B, 4, 24, k0); o = _gpu_op4(buf, o, 0x0004002B, 4, 25, k0*Ckv);
    o = _gpu_op5(buf, o, 0x00050036, 2, 30, 0, 3); o = _gpu_op2(buf, o, 0x000200F8, 31);
    o = _gpu_op4(buf, o, 0x0004003D, 5, 32, 14);
    o = _gpu_op5(buf, o, 0x00050051, 4, 33, 32, 0);
    o = _gpu_op5(buf, o, 0x00050086, 4, 34, 33, 21);     # t2 = idx/hd
    o = _gpu_op5(buf, o, 0x00050084, 4, 35, 34, 21); o = _gpu_op5(buf, o, 0x00050082, 4, 36, 33, 35);  # d
    o = _gpu_op5(buf, o, 0x00050086, 4, 37, 34, 19);     # h = t2/T
    o = _gpu_op5(buf, o, 0x00050084, 4, 38, 37, 19); o = _gpu_op5(buf, o, 0x00050082, 4, 39, 34, 38);  # i
    o = _gpu_op5(buf, o, 0x00050084, 4, 40, 34, 19);     # prow
    o = _gpu_op5(buf, o, 0x00050084, 4, 41, 37, 21);     # hhd
    o = _gpu_op5(buf, o, 0x00050084, 4, 42, 39, 20); o = _gpu_op5(buf, o, 0x00050080, 4, 43, 42, 41);  # i*C+hhd
    o = _gpu_op5(buf, o, 0x00050080, 4, 44, 43, 36);     # coff
    o = _gpu_op5(buf, o, 0x00050080, 4, 45, 41, 36);     # vbase
    o = _gpu_op6(buf, o, 0x00060041, 11, 46, 17, 18, 44); o = _gpu_op4(buf, o, 0x0004003D, 7, 47, 46);  # acc=O[coff]
    o = _gpu_op5(buf, o, 0x00050080, 4, 48, 40, 24);     # pj0 = prow + k0
    o = _gpu_op5(buf, o, 0x00050080, 4, 49, 45, 25);     # vj0 = vbase + k0*Ckv
    var pj=48; var vj=49; var acc=47; var nid=50; var jj=0;
    while (jj < TK) {
        var pp=nid; nid=nid+1; o = _gpu_op6(buf, o, 0x00060041, 11, pp, 15, 18, pj);
        var pv=nid; nid=nid+1; o = _gpu_op4(buf, o, 0x0004003D, 7, pv, pp);
        var vp=nid; nid=nid+1; o = _gpu_op6(buf, o, 0x00060041, 11, vp, 16, 18, vj);
        var vv=nid; nid=nid+1; o = _gpu_op4(buf, o, 0x0004003D, 7, vv, vp);
        var pr=nid; nid=nid+1; o = _gpu_op5(buf, o, 0x00050085, 7, pr, pv, vv);
        var an=nid; nid=nid+1; o = _gpu_op5(buf, o, 0x00050081, 7, an, acc, pr); acc=an;
        if (jj < TK-1) {
            var pn=nid; nid=nid+1; o = _gpu_op5(buf, o, 0x00050080, 4, pn, pj, 23); pj=pn;
            var vn=nid; nid=nid+1; o = _gpu_op5(buf, o, 0x00050080, 4, vn, vj, 22); vj=vn;
        }
        jj = jj + 1;
    }
    o = _gpu_op3(buf, o, 0x0003003E, 46, acc);
    o = _gpu_op2(buf, o, 0x000100FD, 0x00010038); store32(buf+12, nid); return o;
}

# Get (compile+cache) an attention kernel. kind 6=scores 7=rowmax 8=expsum 9=pv.
fn _gpu_get_attn(kind, T, C, hd, Ckv, scale, k0, TK): i64 {
    var key = (kind << 56) | (C << 28) | (T << 14) | k0;
    var c = _gpu_cache_get(key);
    if (c == (0 - 1)) { return 0; }
    if (c != 0) { return c; }
    var spv[8192];
    var nbytes = 0;
    if (kind == 6) { nbytes = _gpu_attn_scores(&spv, T, C, hd, Ckv, scale); }
    elif (kind == 7) { nbytes = _gpu_attn_rowmax(&spv, T, k0, TK); }
    elif (kind == 8) { nbytes = _gpu_attn_expsum(&spv, T, k0, TK); }
    else { nbytes = _gpu_attn_pv(&spv, T, C, hd, Ckv, k0, TK); }
    var shmod = gpu_shader_module_create_spirv(_gpu_ctx, &spv, nbytes);
    if (shmod == 0) { _gpu_cache_put(key, 0 - 1); return 0; }
    _gpu_cache_put(key, shmod);
    return shmod;
}

var _gpu_attn_tk = 4;    # j-tile for the reductions (exp-heavy expsum bounds it)

# Dispatch one attn pass with a (count, (handle,va)…) bind array of `nb` buffers.
fn _gpu_attn_disp(sh, nb, h0,v0, h1,v1, h2,v2, grid): i64 {
    var bp[56];
    store64(&bp+0, nb);
    store64(&bp+8, h0); store64(&bp+16, v0);
    store64(&bp+24, h1); store64(&bp+32, v1);
    store64(&bp+40, h2); store64(&bp+48, v2);
    return gpu_compute_dispatch(_gpu_ctx, sh, grid, 1, 1, &bp);
}

# GPU fused attention core (causal MHA): concat(T,C) from Qc/Kc/Vc, Pc as scratch. Returns 0
# on success, -1 = use CPU. Buffers map onto the pool: Q=x K=W V=gamma P=beta M=S L=V O=y.
# TOLERANCE (in-shader exp) — gated by g_gpu_tc. Causal + full MHA only (nkv==nh, g_bidir==0).
fn gpu_attn_core(Qc, Kc, Vc, Pc, concat, T, C, nh, nkv): i64 {
    if (_gpu_init() == 0) { return 0 - 1; }
    if (nkv != nh) { return 0 - 1; }            # GQA → CPU (kvb mapping). Caller gates bidir.
    var hd = C / nh;
    var Ckv = nkv * hd;
    var TK = _gpu_attn_tk;
    if ((T % TK) != 0) { return 0 - 1; }
    var PN = nh * T * T;
    if ((PN * 8) > GPU_BO_MAX()) { return 0 - 1; }
    if ((PN) > MABDA_MAX_DISPATCH_DIM) { return 0 - 1; }
    if ((nh * T * hd) > MABDA_MAX_DISPATCH_DIM) { return 0 - 1; }
    var scale = f64_div(f64_from(1), f64_sqrt(f64_from(hd)));
    var neg = f64_from(0 - 100000000);          # -1e8 (host inits for M)
    # upload Q→x, K→W, V→gamma
    var i = 0; var qn = T * C;
    while (i < qn) { store64(_gpu_xm + i*8, load64(Qc + i*8)); i = i + 1; }
    i = 0; var kn = T * Ckv;
    while (i < kn) { store64(_gpu_wm + i*8, load64(Kc + i*8)); i = i + 1; }
    i = 0;
    while (i < kn) { store64(_gpu_gm + i*8, load64(Vc + i*8)); i = i + 1; }
    # init M(S)=-1e8, L(V)=0, O(y)=0
    var MT = nh * T;
    i = 0; while (i < MT) { store64(_gpu_sm + i*8, neg); store64(_gpu_vm + i*8, f64_from(0)); i = i + 1; }
    i = 0; var on = T * C; while (i < on) { store64(_gpu_ym + i*8, f64_from(0)); i = i + 1; }
    # P1 scores → P (beta buffer)
    var sh = _gpu_get_attn(6, T, C, hd, Ckv, scale, 0, TK);
    if (sh == 0) { return 0 - 1; }
    if (_gpu_attn_disp(sh, 3, _gpu_xh, _GPU_XVA(), _gpu_wh, _GPU_WVA(), _gpu_bbh, _GPU_BVA(), PN) != 0) {
        return 0 - 1;
    }
    # P2 rowmax tiles → M (S)
    var k0 = 0;
    while (k0 < T) {
        var s2 = _gpu_get_attn(7, T, C, hd, Ckv, scale, k0, TK);
        if (s2 == 0) { return 0 - 1; }
        if (_gpu_attn_disp(s2, 2, _gpu_bbh, _GPU_BVA(), _gpu_sh, _GPU_SVA(), 0, 0, MT) != 0) { return 0 - 1; }
        k0 = k0 + TK;
    }
    # P3 exp+sum tiles → P (exp), L (V)
    k0 = 0;
    while (k0 < T) {
        var s3 = _gpu_get_attn(8, T, C, hd, Ckv, scale, k0, TK);
        if (s3 == 0) { return 0 - 1; }
        if (_gpu_attn_disp(s3, 3, _gpu_bbh, _GPU_BVA(), _gpu_sh, _GPU_SVA(), _gpu_vh, _GPU_VVA(), MT) != 0) {
            return 0 - 1;
        }
        k0 = k0 + TK;
    }
    # host: L := 1/L
    i = 0; while (i < MT) { store64(_gpu_vm + i*8, f64_div(f64_from(1), load64(_gpu_vm + i*8))); i = i + 1; }
    # P4 pv tiles → O (y), RMW. bindings P=beta, V=gamma, O=y; grid nh*T*hd
    k0 = 0;
    while (k0 < T) {
        var s4 = _gpu_get_attn(9, T, C, hd, Ckv, scale, k0, TK);
        if (s4 == 0) { return 0 - 1; }
        if (_gpu_attn_disp(s4, 3, _gpu_bbh, _GPU_BVA(), _gpu_gh, _GPU_GVA(), _gpu_yh, _GPU_YVA(), nh*T*hd) != 0) {
            return 0 - 1;
        }
        k0 = k0 + TK;
    }
    # normalize O[i*C+h*hd+d] *= 1/sum[h*T+i]
    var h = 0;
    while (h < nh) {
        var ii = 0;
        while (ii < T) {
            var invv = load64(_gpu_vm + (h*T + ii)*8); var dd = 0;
            while (dd < hd) {
                var ci = ii*C + h*hd + dd; store64(_gpu_ym + ci*8, f64_mul(load64(_gpu_ym + ci*8), invv)); dd = dd + 1;
            }
            ii = ii + 1;
        }
        h = h + 1;
    }
    i = 0; while (i < on) { store64(concat + i*8, load64(_gpu_ym + i*8)); i = i + 1; }
    _gpu_attn_count = _gpu_attn_count + 1;
    return 0;
}

# ===========================================================================
# 1.8.5 — Adam optimizer step on GPU, BIT-EXACT (the first backward-arc op). Elementwise over
# the flat param vector: m=b1·m+om1·g; v=b2·v+om2·g²; p-=lr·(m/bc1)/(√(v/bc2)+eps) — EXACTLY
# model_adam_step (model.cyr). In-shader f64 sqrt + FDiv are correctly-rounded vs the CPU
# (verified bit-for-bit on Cezanne), so this keeps a --gpu run's checkpoint byte-identical to
# CPU — it rides plain g_gpu (NOT g_gpu_tc). The 8 scalars (b1 b2 om1 om2 eps bc1 bc2 lr) are
# host-computed identically + passed as a uniform buffer (no baked hex → guaranteed bit-exact);
# grid host-tiled in MABDA_MAX_DISPATCH_DIM chunks (g_NP exceeds it at preset).
# ===========================================================================

# Adam kernel: grads=0(%15) params=1(%16) m=2(%17) v=3(%18) scalars=4(%19). consts %20..27=0..7
# (member/scalar indices) %28=base. idx=gid.x+base. fn %30.
fn _gpu_adam_k(buf, base): i64 {
    var o = _gpu_pre_a(buf, 5, 30);
    var k = 0; while (k <= 7) { o = _gpu_op4(buf, o, 0x0004002B, 4, 20+k, k); k = k+1; }
    o = _gpu_op4(buf, o, 0x0004002B, 4, 28, base);
    o = _gpu_op5(buf, o, 0x00050036, 2, 30, 0, 3); o = _gpu_op2(buf, o, 0x000200F8, 31);
    o = _gpu_op4(buf, o, 0x0004003D, 5, 32, 14);
    o = _gpu_op5(buf, o, 0x00050051, 4, 33, 32, 0);          # gid.x
    o = _gpu_op5(buf, o, 0x00050080, 4, 34, 33, 28);        # idx = gid.x + base
    var nid = 35;
    # load b1 b2 om1 om2 eps bc1 bc2 lr from scalars(%19); g m v p from their bindings (idx %34)
    var b1=nid+1;  o=_gpu_acl(buf,o,nid,b1,19,20,20); nid=nid+2;
    var b2=nid+1;  o=_gpu_acl(buf,o,nid,b2,19,20,21); nid=nid+2;
    var om1=nid+1; o=_gpu_acl(buf,o,nid,om1,19,20,22); nid=nid+2;
    var om2=nid+1; o=_gpu_acl(buf,o,nid,om2,19,20,23); nid=nid+2;
    var eps=nid+1; o=_gpu_acl(buf,o,nid,eps,19,20,24); nid=nid+2;
    var bc1=nid+1; o=_gpu_acl(buf,o,nid,bc1,19,20,25); nid=nid+2;
    var bc2=nid+1; o=_gpu_acl(buf,o,nid,bc2,19,20,26); nid=nid+2;
    var lr=nid+1;  o=_gpu_acl(buf,o,nid,lr,19,20,27); nid=nid+2;
    var g=nid+1;   o=_gpu_acl(buf,o,nid,g,15,20,34); nid=nid+2;
    var pm=nid;    var mo=nid+1; o=_gpu_acl(buf,o,pm,mo,17,20,34); nid=nid+2;
    var pv=nid;    var vo=nid+1; o=_gpu_acl(buf,o,pv,vo,18,20,34); nid=nid+2;
    var pp=nid;    var po=nid+1; o=_gpu_acl(buf,o,pp,po,16,20,34); nid=nid+2;
    var t1=nid; nid=nid+1; o=_gpu_op5(buf,o,0x00050085,7,t1,b1,mo);
    var t2=nid; nid=nid+1; o=_gpu_op5(buf,o,0x00050085,7,t2,om1,g);
    var mn=nid; nid=nid+1; o=_gpu_op5(buf,o,0x00050081,7,mn,t1,t2);
    var gg=nid; nid=nid+1; o=_gpu_op5(buf,o,0x00050085,7,gg,g,g);
    var t3=nid; nid=nid+1; o=_gpu_op5(buf,o,0x00050085,7,t3,b2,vo);
    var t4=nid; nid=nid+1; o=_gpu_op5(buf,o,0x00050085,7,t4,om2,gg);
    var vn=nid; nid=nid+1; o=_gpu_op5(buf,o,0x00050081,7,vn,t3,t4);
    o=_gpu_op3(buf,o,0x0003003E,pm,mn); o=_gpu_op3(buf,o,0x0003003E,pv,vn);
    var mh=nid;nid=nid+1;o=_gpu_op5(buf,o,0x00050088,7,mh,mn,bc1);
    var vh=nid;nid=nid+1;o=_gpu_op5(buf,o,0x00050088,7,vh,vn,bc2);
    var sq=nid;nid=nid+1;o=_gpu_op6(buf,o,0x0006000C,7,sq,1,31,vh);
    var den=nid;nid=nid+1;o=_gpu_op5(buf,o,0x00050081,7,den,sq,eps);
    var upd=nid;nid=nid+1;o=_gpu_op5(buf,o,0x00050088,7,upd,mh,den);
    var lu=nid;nid=nid+1;o=_gpu_op5(buf,o,0x00050085,7,lu,lr,upd);
    var pn=nid;nid=nid+1;o=_gpu_op5(buf,o,0x00050083,7,pn,po,lu);
    o=_gpu_op3(buf,o,0x0003003E,pp,pn);
    o = _gpu_op2(buf, o, 0x000100FD, 0x00010038); store32(buf+12, nid); return o;
}

# Compile+cache an Adam kernel (kind 12, keyed by base).
fn _gpu_get_adam(base): i64 {
    var key = (12 << 56) | base;
    var c = _gpu_cache_get(key);
    if (c == (0 - 1)) { return 0; }
    if (c != 0) { return c; }
    var spv[8192];
    var nbytes = _gpu_adam_k(&spv, base);
    var shmod = gpu_shader_module_create_spirv(_gpu_ctx, &spv, nbytes);
    if (shmod == 0) { _gpu_cache_put(key, 0 - 1); return 0; }
    _gpu_cache_put(key, shmod);
    return shmod;
}

# GPU Adam step (BIT-EXACT, plain --gpu). Mirrors model_adam_step over the caller's flat
# params/grads/m/v vectors (NP entries each) — buffers passed in so gpu.cyr stays free of model
# globals. Returns 0 = ran on device, -1 = use CPU. lr is an f64 bit pattern; step is the
# 1-based Adam timestep.
fn gpu_adam_step(params, grads, m, v, NP, lr, step): i64 {
    if (_gpu_init() == 0) { return 0 - 1; }
    if ((NP * 8) > GPU_BO_MAX()) { return 0 - 1; }
    # host-compute the 8 scalars EXACTLY as model_adam_step (bit-identical inputs)
    var b1 = f64_div(f64_from(9), f64_from(10));
    var b2 = f64_div(f64_from(999), f64_from(1000));
    var om1 = f64_div(f64_from(1), f64_from(10));
    var om2 = f64_div(f64_from(1), f64_from(1000));
    var eps = f64_div(f64_from(1), f64_from(100000000));
    var one = f64_from(1);
    var bc1 = f64_sub(one, f64_pow(b1, f64_from(step)));
    var bc2 = f64_sub(one, f64_pow(b2, f64_from(step)));
    store64(_gpu_sm + 0, b1); store64(_gpu_sm + 8, b2); store64(_gpu_sm + 16, om1);
    store64(_gpu_sm + 24, om2); store64(_gpu_sm + 32, eps); store64(_gpu_sm + 40, bc1);
    store64(_gpu_sm + 48, bc2); store64(_gpu_sm + 56, lr);
    # upload grads→x, params→W, m→gamma, v→beta
    var i = 0;
    while (i < NP) { store64(_gpu_xm + i*8, load64(grads + i*8)); i = i + 1; }
    i = 0; while (i < NP) { store64(_gpu_wm + i*8, load64(params + i*8)); i = i + 1; }
    i = 0; while (i < NP) { store64(_gpu_gm + i*8, load64(m + i*8)); i = i + 1; }
    i = 0; while (i < NP) { store64(_gpu_bbm + i*8, load64(v + i*8)); i = i + 1; }
    # dispatch in MABDA_MAX_DISPATCH_DIM chunks (NP exceeds it at preset)
    var base = 0;
    while (base < NP) {
        var n = NP - base;
        if (n > MABDA_MAX_DISPATCH_DIM) { n = MABDA_MAX_DISPATCH_DIM; }
        var sh = _gpu_get_adam(base);
        if (sh == 0) { return 0 - 1; }
        var bp[96];
        store64(&bp+0, 5);
        store64(&bp+8, _gpu_xh); store64(&bp+16, _GPU_XVA());
        store64(&bp+24, _gpu_wh); store64(&bp+32, _GPU_WVA());
        store64(&bp+40, _gpu_gh); store64(&bp+48, _GPU_GVA());
        store64(&bp+56, _gpu_bbh); store64(&bp+64, _GPU_BVA());
        store64(&bp+72, _gpu_sh); store64(&bp+80, _GPU_SVA());
        if (gpu_compute_dispatch(_gpu_ctx, sh, n, 1, 1, &bp) != 0) { return 0 - 1; }
        base = base + n;
    }
    # download params/m/v (RMW in place in the BOs)
    i = 0; while (i < NP) { store64(params + i*8, load64(_gpu_wm + i*8)); i = i + 1; }
    i = 0; while (i < NP) { store64(m + i*8, load64(_gpu_gm + i*8)); i = i + 1; }
    i = 0; while (i < NP) { store64(v + i*8, load64(_gpu_bbm + i*8)); i = i + 1; }
    _gpu_adam_count = _gpu_adam_count + 1;
    return 0;
}

# ===========================================================================
# 1.9.1 — RoPE Q/K rotation on GPU, BIT-EXACT (M19 remaining-op coverage). The rotation angles
# (cos/sin) are a function of (position, channel-pair) ONLY — data-independent — so the host
# precomputes the cos/sin TABLE bit-for-bit (the proven Maclaurin + binary-exponentiation path
# stays on the CPU) and the GPU does ONLY the rotation (pure f64 mul/add/sub, correctly-rounded) →
# bit-identical to rope_apply_fwd/bwd → rides PLAIN --gpu, keeps the checkpoint byte-identical.
# One thread per (row, head, pair). dir 0 = forward R(angle), dir 1 = backward Rᵀ. The caller
# (src/attn.cyr) builds the table; gpu.cyr stays self-contained (table passed as a buffer).
# ===========================================================================

# Rotate X(rows,width) in place by a precomputed cos/sin table. X=0(%12,io) cs=1(%13). grid
# rows·NH·hdp; idx→(r,h,k). pair = X[r·width + h·hd + 2k]; (c,s) = cs[(r·hdp+k)·2]. dir picks the
# fwd/bwd sign pattern. consts %14=0 %15=width %16=hd %17=hdp %18=HK(=NH·hdp) %19=1 %20=2.
fn _gpu_build_rope(buf, width, hd, hdp, NH, dir): i64 {
    var HK = NH * hdp;
    var o = _gpu_pre(buf, 2, 21);
    o=_gpu_op4(buf,o,0x0004002B,3,14,0); o=_gpu_op4(buf,o,0x0004002B,3,15,width);
    o=_gpu_op4(buf,o,0x0004002B,3,16,hd); o=_gpu_op4(buf,o,0x0004002B,3,17,hdp);
    o=_gpu_op4(buf,o,0x0004002B,3,18,HK); o=_gpu_op4(buf,o,0x0004002B,3,19,1);
    o=_gpu_op4(buf,o,0x0004002B,3,20,2);
    o=_gpu_op5(buf,o,0x00050036,1,21,0,2); o=_gpu_op2(buf,o,0x000200F8,22);
    o=_gpu_op4(buf,o,0x0004003D,4,23,11); o=_gpu_op5(buf,o,0x00050051,3,24,23,0);   # idx
    o=_gpu_op5(buf,o,0x00050086,3,25,24,18);                       # r = idx/HK
    o=_gpu_op5(buf,o,0x00050084,3,26,25,18); o=_gpu_op5(buf,o,0x00050082,3,27,24,26);   # rem = idx - r*HK
    o=_gpu_op5(buf,o,0x00050086,3,28,27,17);                       # h = rem/hdp
    o=_gpu_op5(buf,o,0x00050084,3,29,28,17); o=_gpu_op5(buf,o,0x00050082,3,30,27,29);   # k = rem - h*hdp
    o=_gpu_op5(buf,o,0x00050084,3,31,25,15);                       # r*width
    o=_gpu_op5(buf,o,0x00050084,3,32,28,16);                       # h*hd
    o=_gpu_op5(buf,o,0x00050084,3,33,30,20);                       # 2k
    o=_gpu_op5(buf,o,0x00050080,3,34,31,32); o=_gpu_op5(buf,o,0x00050080,3,35,34,33);   # Xbase
    o=_gpu_op5(buf,o,0x00050080,3,36,35,19);                       # Xbase+1
    o=_gpu_op5(buf,o,0x00050084,3,37,25,17); o=_gpu_op5(buf,o,0x00050080,3,38,37,30);   # r*hdp+k
    o=_gpu_op5(buf,o,0x00050084,3,39,38,20); o=_gpu_op5(buf,o,0x00050080,3,40,39,19);   # csbase, csbase+1
    o=_gpu_acl6(buf,o,41,42,12,14,35);                            # x0 = X[Xbase]
    o=_gpu_acl6(buf,o,43,44,12,14,36);                            # x1 = X[Xbase+1]
    o=_gpu_acl6(buf,o,45,46,13,14,39);                            # c
    o=_gpu_acl6(buf,o,47,48,13,14,40);                            # s
    o=_gpu_op5(buf,o,0x00050085,6,49,42,46);                      # x0*c
    o=_gpu_op5(buf,o,0x00050085,6,50,44,48);                      # x1*s
    o=_gpu_op5(buf,o,0x00050085,6,52,42,48);                      # x0*s
    o=_gpu_op5(buf,o,0x00050085,6,53,44,46);                      # x1*c
    if (dir == 0) {
        o=_gpu_op5(buf,o,0x00050083,6,51,49,50);                  # fwd y0 = x0c - x1s
        o=_gpu_op5(buf,o,0x00050081,6,54,52,53);                  # fwd y1 = x0s + x1c
    } else {
        o=_gpu_op5(buf,o,0x00050081,6,51,49,50);                  # bwd y0 = d0c + d1s
        o=_gpu_op5(buf,o,0x00050083,6,54,53,52);                  # bwd y1 = d1c - d0s
    }
    o=_gpu_op3(buf,o,0x0003003E,41,51);                           # X[Xbase] = y0
    o=_gpu_op3(buf,o,0x0003003E,43,54);                           # X[Xbase+1] = y1
    o=_gpu_op2(buf,o,0x000100FD,0x00010038); store32(buf+12,55); return o;
}

fn _gpu_get_rope(width, hd, hdp, NH, dir): i64 {
    var key = (22 << 56) | (dir << 55) | (width << 40) | (hd << 28) | (hdp << 20) | NH;
    var c = _gpu_cache_get(key); if (c == (0 - 1)) { return 0; } if (c != 0) { return c; }
    var spv[8192]; var nb = _gpu_build_rope(&spv, width, hd, hdp, NH, dir);
    var sh = gpu_shader_module_create_spirv(_gpu_ctx, &spv, nb);
    if (sh == 0) { _gpu_cache_put(key, 0 - 1); return 0; }
    _gpu_cache_put(key, sh); return sh;
}

# GPU RoPE: rotate X(rows,width) in place given the host-precomputed cos/sin table cs (layout
# cs[(r·hdp+k)·2]=c, +1=s). dir 0 = forward, 1 = backward. Returns 0 = ran (X rotated), -1 = CPU.
# BIT-EXACT vs rope_apply_fwd/bwd → plain --gpu. rows<2 (decode) self-falls-back (not worth a dispatch).
fn gpu_rope_apply(X, cs, rows, width, num_heads, hdp, dir): i64 {
    if (_gpu_init() == 0) { return 0 - 1; }
    if (rows < 2) { return 0 - 1; }
    if (num_heads <= 0) { return 0 - 1; }
    if (width <= 0) { return 0 - 1; }
    var hd = width / num_heads;
    if ((hd % 2) != 0) { return 0 - 1; }
    if (hdp != (hd / 2)) { return 0 - 1; }
    if (hdp <= 0) { return 0 - 1; }
    var grid = rows * num_heads * hdp;
    if (grid <= 0) { return 0 - 1; }
    if (grid > MABDA_MAX_DISPATCH_DIM) { return 0 - 1; }
    var nx = rows * width; var ncs = rows * hdp * 2;
    if ((nx * 8) > GPU_BO_MAX()) { return 0 - 1; }
    if ((ncs * 8) > GPU_BO_MAX()) { return 0 - 1; }
    var sh = _gpu_get_rope(width, hd, hdp, num_heads, dir);
    if (sh == 0) { return 0 - 1; }
    var i = 0;
    while (i < nx) { store64(_gpu_xm + i*8, load64(X + i*8)); i = i + 1; }
    i = 0; while (i < ncs) { store64(_gpu_wm + i*8, load64(cs + i*8)); i = i + 1; }
    var bp[40]; store64(&bp+0, 2);
    store64(&bp+8, _gpu_xh); store64(&bp+16, _GPU_XVA());
    store64(&bp+24, _gpu_wh); store64(&bp+32, _GPU_WVA());
    if (gpu_compute_dispatch(_gpu_ctx, sh, grid, 1, 1, &bp) != 0) { return 0 - 1; }
    i = 0; while (i < nx) { store64(X + i*8, load64(_gpu_xm + i*8)); i = i + 1; }
    _gpu_rope_count = _gpu_rope_count + 1;
    return 0;
}

# gpu_probe — bring the native GPU context up, report device + f64 capability, release.
# Returns 0 = GPU online; 1 = no native device (clean fallback). Used by main's --gpu.
fn gpu_probe(): i64 {
    var res = gpu_context_new_native();
    if (is_err_result(res) == 1) {
        puts("GPU: no native AMD device available — CPU path unaffected\n");
        return 1;
    }
    var ctx = payload(res);
    puts("GPU: native AMD compute device online (launcher-free, pure-Cyrius)\n");
    if (gpu_caps_native_shader_f64() == 1) {
        puts("GPU: f64 SPIR-V compute supported — matmul on-device (CPU stays the oracle)\n");
    } else {
        puts("GPU: f64 SPIR-V compute UNSUPPORTED on this device — CPU fallback\n");
    }
    gpu_context_release(ctx);
    return 0;
}
