# f64 OpConstant for _gpu_pre kernels (double type is %6, not the attn preamble's %7 that _gpu_ecf uses).
fn _gpu_ecf6(buf, o, id, bits): i64 {
    store32(buf + o, 0x0005002B); store32(buf + o + 4, 6); store32(buf + o + 8, id);
    store32(buf + o + 12, bits & 0xFFFFFFFF); store32(buf + o + 16, (bits >> 32) & 0xFFFFFFFF);
