# Generate the GPU_TK-tile RMW matmul kernel for (K, N, k0) into buf; return bytes.
# Bindings: x=0, W=1, y=2. Consts %16=0 %17=1 %18=K %19=N %20=k0 %21=k0·N. Fn %22.
fn _gpu_build_tile(buf, K, N, k0, TK): i64 {
    var k0N = k0 * N;
    var o = _gpu_op3(buf, 0, 0x07230203, 0x00010300, 0x00000000);   # magic / version 1.3 / gen
    var bound_off = o;
    o = _gpu_op2(buf, o, 0x00000000, 0x00000000);                   # id-bound (patched) + schema
    o = _gpu_op2(buf, o, 0x00020011, 1);                            # Capability Shader
    o = _gpu_op2(buf, o, 0x00020011, 10);                           # Capability Float64
    o = _gpu_op3(buf, o, 0x0003000E, 0, 1);                         # MemoryModel Logical GLSL450
    o = _gpu_op6(buf, o, 0x0006000F, 5, 22, 0x6E69616D, 0x00000000, 11);  # EntryPoint GLCompute %22 "main" %11
    o = _gpu_op6(buf, o, 0x00060010, 22, 17, 1, 1, 1);             # ExecutionMode LocalSize 1 1 1
    # decorations: gid BuiltIn GlobalInvocationId + 3 storage buffers (Binding/DescSet)
    o = _gpu_op4(buf, o, 0x00040047, 11, 11, 28);                  # %11 BuiltIn GlobalInvocationId
    o = _gpu_op4(buf, o, 0x00040047, 12, 33, 0);                   # %12 x Binding 0
    o = _gpu_op4(buf, o, 0x00040047, 12, 34, 0);                   # %12 x DescriptorSet 0
    o = _gpu_op4(buf, o, 0x00040047, 13, 33, 1);                   # %13 W Binding 1
    o = _gpu_op4(buf, o, 0x00040047, 13, 34, 0);                   # %13 W DescriptorSet 0
    o = _gpu_op4(buf, o, 0x00040047, 14, 33, 2);                   # %14 y Binding 2
    o = _gpu_op4(buf, o, 0x00040047, 14, 34, 0);                   # %14 y DescriptorSet 0
    # types / pointers / consts / variables
    o = _gpu_op2(buf, o, 0x00020013, 1);                           # %1 void
    o = _gpu_op3(buf, o, 0x00030021, 2, 1);                        # %2 fn void()
    o = _gpu_op4(buf, o, 0x00040015, 3, 32, 0);                    # %3 uint
    o = _gpu_op4(buf, o, 0x00040017, 4, 3, 3);                     # %4 uvec3
    o = _gpu_op4(buf, o, 0x00040020, 5, 1, 4);                     # %5 ptr Input uvec3
    o = _gpu_op3(buf, o, 0x00030016, 6, 64);                       # %6 double
    o = _gpu_op3(buf, o, 0x0003001D, 7, 6);                        # %7 runtimearray double
    o = _gpu_op3(buf, o, 0x0003001E, 8, 7);                        # %8 struct {array}
    o = _gpu_op4(buf, o, 0x00040020, 9, 12, 8);                    # %9 ptr StorageBuffer struct
    o = _gpu_op4(buf, o, 0x00040020, 10, 12, 6);                   # %10 ptr StorageBuffer double
    o = _gpu_op4(buf, o, 0x0004002B, 3, 16, 0);                    # %16 = 0
    o = _gpu_op4(buf, o, 0x0004002B, 3, 17, 1);                    # %17 = 1
    o = _gpu_op4(buf, o, 0x0004002B, 3, 18, K);                    # %18 = K
    o = _gpu_op4(buf, o, 0x0004002B, 3, 19, N);                    # %19 = N
    o = _gpu_op4(buf, o, 0x0004002B, 3, 20, k0);                   # %20 = k0
    o = _gpu_op4(buf, o, 0x0004002B, 3, 21, k0N);                  # %21 = k0·N
    o = _gpu_op4(buf, o, 0x0004003B, 5, 11, 1);                    # %11 gid var Input
    o = _gpu_op4(buf, o, 0x0004003B, 9, 12, 12);                   # %12 x var StorageBuffer
    o = _gpu_op4(buf, o, 0x0004003B, 9, 13, 12);                   # %13 W var StorageBuffer
    o = _gpu_op4(buf, o, 0x0004003B, 9, 14, 12);                   # %14 y var StorageBuffer
    # function body
    o = _gpu_op5(buf, o, 0x00050036, 1, 22, 0, 2);                 # %22 Function void() None
    o = _gpu_op2(buf, o, 0x000200F8, 23);                         # %23 Label
    o = _gpu_op4(buf, o, 0x0004003D, 4, 24, 11);                  # %24 = Load gid
    o = _gpu_op5(buf, o, 0x00050051, 3, 25, 24, 0);              # %25 idx = gid.x
    o = _gpu_op5(buf, o, 0x00050086, 3, 26, 25, 19);            # %26 m  = idx / N (UDiv)
    o = _gpu_op5(buf, o, 0x00050089, 3, 27, 25, 19);            # %27 n  = idx % N (UMod)
    o = _gpu_op5(buf, o, 0x00050084, 3, 28, 26, 18);            # %28 mK = m * K   (IMul)
    o = _gpu_op5(buf, o, 0x00050080, 3, 29, 28, 20);            # %29 xi = mK + k0 (IAdd)
    o = _gpu_op5(buf, o, 0x00050080, 3, 30, 27, 21);            # %30 wi = n + k0N (IAdd)
    o = _gpu_op6(buf, o, 0x00060041, 10, 31, 14, 16, 25);      # %31 = &y[idx]
    o = _gpu_op4(buf, o, 0x0004003D, 6, 32, 31);               # %32 acc = y[idx] (RMW base)
    var xi = 29; var wi = 30; var acc = 32; var nid = 33;
    var j = 0;
    while (j < TK) {
        var ax = nid; nid = nid + 1;
        o = _gpu_op6(buf, o, 0x00060041, 10, ax, 12, 16, xi);     # &x[xi]
        var vx = nid; nid = nid + 1;
        o = _gpu_op4(buf, o, 0x0004003D, 6, vx, ax);             # x[xi]
        var aw = nid; nid = nid + 1;
        o = _gpu_op6(buf, o, 0x00060041, 10, aw, 13, 16, wi);     # &W[wi]
        var vw = nid; nid = nid + 1;
        o = _gpu_op4(buf, o, 0x0004003D, 6, vw, aw);             # W[wi]
        var prod = nid; nid = nid + 1;
        o = _gpu_op5(buf, o, 0x00050085, 6, prod, vx, vw);       # x*W (FMul)
        var accn = nid; nid = nid + 1;
        o = _gpu_op5(buf, o, 0x00050081, 6, accn, acc, prod);    # acc += prod (FAdd)
        acc = accn;
        if (j < TK - 1) {
            var xin = nid; nid = nid + 1;
            o = _gpu_op5(buf, o, 0x00050080, 3, xin, xi, 17);    # xi += 1
            var win = nid; nid = nid + 1;
            o = _gpu_op5(buf, o, 0x00050080, 3, win, wi, 19);    # wi += N
            xi = xin; wi = win;
        }
        j = j + 1;
    }
    o = _gpu_op3(buf, o, 0x0003003E, 31, acc);   # Store y[idx] = acc
    o = _gpu_op2(buf, o, 0x000100FD, 0x00010038);   # Return ; FunctionEnd (1-word ops packed)
    store32(buf + bound_off, nid);   # id bound = next free id
    return o;
}

# TRANSPOSED-weight tile kernel for the LM head: y[m,n] = Σ_k x[m*K+k] · W[n*K+k] (W is the
# tied embedding, row-major V×C, contracted on its last dim). Identical to _gpu_build_tile
# except the W index is n*K+k (advance +1) not k*N+n (advance +N). Sequential reduction, so
# vs the CPU head's 4-lane-tree dot it matches only to ~1e-15 → rides --gpu-tc (tolerance).
fn _gpu_build_tile_t(buf, K, N, k0, TK): i64 {
    var o = _gpu_op3(buf, 0, 0x07230203, 0x00010300, 0x00000000);
    var bound_off = o;
    o = _gpu_op2(buf, o, 0x00000000, 0x00000000);
    o = _gpu_op2(buf, o, 0x00020011, 1); o = _gpu_op2(buf, o, 0x00020011, 10);
    o = _gpu_op3(buf, o, 0x0003000E, 0, 1);
    o = _gpu_op6(buf, o, 0x0006000F, 5, 22, 0x6E69616D, 0x00000000, 11);
    o = _gpu_op6(buf, o, 0x00060010, 22, 17, 1, 1, 1);
    o = _gpu_op4(buf, o, 0x00040047, 11, 11, 28);
    o = _gpu_op4(buf, o, 0x00040047, 12, 33, 0); o = _gpu_op4(buf, o, 0x00040047, 12, 34, 0);
    o = _gpu_op4(buf, o, 0x00040047, 13, 33, 1); o = _gpu_op4(buf, o, 0x00040047, 13, 34, 0);
    o = _gpu_op4(buf, o, 0x00040047, 14, 33, 2); o = _gpu_op4(buf, o, 0x00040047, 14, 34, 0);
    o = _gpu_op2(buf, o, 0x00020013, 1); o = _gpu_op3(buf, o, 0x00030021, 2, 1);
    o = _gpu_op4(buf, o, 0x00040015, 3, 32, 0); o = _gpu_op4(buf, o, 0x00040017, 4, 3, 3);
    o = _gpu_op4(buf, o, 0x00040020, 5, 1, 4); o = _gpu_op3(buf, o, 0x00030016, 6, 64);
    o = _gpu_op3(buf, o, 0x0003001D, 7, 6); o = _gpu_op3(buf, o, 0x0003001E, 8, 7);
    o = _gpu_op4(buf, o, 0x00040020, 9, 12, 8); o = _gpu_op4(buf, o, 0x00040020, 10, 12, 6);
    o = _gpu_op4(buf, o, 0x0004002B, 3, 16, 0); o = _gpu_op4(buf, o, 0x0004002B, 3, 17, 1);
    o = _gpu_op4(buf, o, 0x0004002B, 3, 18, K); o = _gpu_op4(buf, o, 0x0004002B, 3, 19, N);
    o = _gpu_op4(buf, o, 0x0004002B, 3, 20, k0);
    o = _gpu_op4(buf, o, 0x0004003B, 5, 11, 1);
    o = _gpu_op4(buf, o, 0x0004003B, 9, 12, 12); o = _gpu_op4(buf, o, 0x0004003B, 9, 13, 12);
    o = _gpu_op4(buf, o, 0x0004003B, 9, 14, 12);
    o = _gpu_op5(buf, o, 0x00050036, 1, 22, 0, 2); o = _gpu_op2(buf, o, 0x000200F8, 23);
    o = _gpu_op4(buf, o, 0x0004003D, 4, 24, 11);                  # gid
    o = _gpu_op5(buf, o, 0x00050051, 3, 25, 24, 0);              # idx
    o = _gpu_op5(buf, o, 0x00050086, 3, 26, 25, 19);            # m = idx/N
    o = _gpu_op5(buf, o, 0x00050089, 3, 27, 25, 19);            # n = idx%N
    o = _gpu_op5(buf, o, 0x00050084, 3, 28, 26, 18);            # mK = m*K
    o = _gpu_op5(buf, o, 0x00050080, 3, 29, 28, 20);            # xi = mK + k0
    o = _gpu_op5(buf, o, 0x00050084, 3, 30, 27, 18);            # nK = n*K
    o = _gpu_op5(buf, o, 0x00050080, 3, 31, 30, 20);            # wi = nK + k0
    o = _gpu_op6(buf, o, 0x00060041, 10, 32, 14, 16, 25);      # &y[idx]
    o = _gpu_op4(buf, o, 0x0004003D, 6, 33, 32);               # acc = y[idx]
    var xi = 29; var wi = 31; var acc = 33; var nid = 34;
    var j = 0;
    while (j < TK) {
        var ax = nid; nid = nid + 1;
        o = _gpu_op6(buf, o, 0x00060041, 10, ax, 12, 16, xi);     # &x[xi]
        var vx = nid; nid = nid + 1;
        o = _gpu_op4(buf, o, 0x0004003D, 6, vx, ax);
        var aw = nid; nid = nid + 1;
        o = _gpu_op6(buf, o, 0x00060041, 10, aw, 13, 16, wi);     # &W[wi] (emb[n*K+k])
        var vw = nid; nid = nid + 1;
        o = _gpu_op4(buf, o, 0x0004003D, 6, vw, aw);
        var prod = nid; nid = nid + 1;
